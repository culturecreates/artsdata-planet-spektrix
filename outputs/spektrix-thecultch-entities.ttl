<http://www.spektrix.com/thecultch/event/130801APPNPBCNHKVLRRCJDGTVHDCNBKC> a schema:Event;
  schema:name "Reading: Panty Sniffers";
  schema:description """
	<span class=\"BoldText\">Jenna \"Murphy\" Morgan & Murphy Morgan Presents</span><span><br/></span><span><br/></span>Jim Green House Studio 1885 Venables St.<span><br/></span><span><br/></span>Two broke roommates, Mia and Blake, need a way to pay the rent and they need it fast. Selling used underwear online seems like the proper course of action right? However, nothing comes easy as they must hide their adventure from their overtly conservative landlord and Mia’s controlling trust fund boyfriend. This comical play opens up conversations about sex work, sexuality, low income living, and finally breaking up with your dirtbag boyfriend.<span><br/></span><span><br/></span>All <span class=\"BoldText\">rEvolver Festival readings</span> are by donation and <span class=\"BoldText\">100% of all donations go directly to the artists. </span><span><br/></span><span><br/></span>Donations start at a minimum of $5 (which comes to just under $9 after ticketing fees) and range up to $30. If you have more to give and would like to increase your donation, there is an option to do so at the checkout window.<span><br/></span><span><br/></span>Please note: readings cannot be booked with your festival pass.<span><br/></span><span><br/></span>Thank you for supporting emerging artists!<span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: 18+, strong language, sexual content<span><br/></span><span><br/></span><span class=\"BoldText\">Talkback</span>: May 30<span><br/></span>
""";
  schema:startDate "2026-05-30T15:45:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/afc533e9-eff7-4c0f-a1a3-2ad43baf61fe.jpg>;
  schema:location <https://spektrix.com/thecultch/location/1201AQKTLDJVPVNVGVNTLHSSDPLSGRGBT>;
  schema:offers _:ec4383dd32b74b0f85c637f958b321f82786;
  schema:duration "PT80M";
  schema:endDate "2026-05-30T17:05:00"^^xsd:dateTime .

_:ec4383dd32b74b0f85c637f958b321f82786 a schema:AggregateOffer;
  schema:lowPrice "5.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/thecultch/event/131601ADBGLDRVQKGBQBCSBTRLNPTJMVL> a schema:Event;
  schema:name "Regarding Antigone";
  schema:description """
	<span class=\"BoldText\">Banafsheh Hassani & The Sky is the Limit Theatre & Sort Of Productions</span><span><br/></span><span><br/></span>Vancity Culture Lab 1895 Venables St. <span><br/></span><span><br/></span>Why are you just watching me die?<span><br/></span><span><br/></span>A new play where \"every line is a call to action\", Regarding Antigone is inspired by a true story, and inspired by the classic Greek tragedy of Antigone, and inspired by war photography, and inspired by my weak memory, and inspired by a revolution, and inspired by state propaganda, and inspired by a song she sang, and inspired by cringe diaspora poetry, and-<span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: 16+, Mentions of death, state violence, state murder, suicide, gore, abduction, and guns. Depictions of death and blood. Use of fake blood, and mature language.<span><br/></span><span><br/></span><span class=\"BoldText\">Talkbacks</span>: Following each performance<span><br/></span>
""";
