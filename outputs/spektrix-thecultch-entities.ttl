<http://www.spektrix.com/thecultch/event/123001AGHNSJRVHJLCBPQCBCNMRNLTGMH> a schema:Event;
  schema:name "FREE KITTENS";
  schema:description """
	<span class=\"BoldText\">Megan Milton</span><span><br/></span><span><br/></span>Vancity Culture Lab 1895 Venables St. <span><br/></span><span><br/></span>Megan Milton thinks she should have been an abortion, and after watching FREE KITTENS, you might too (but don’t worry, it’s a comedy).<span><br/></span><span><br/></span>FREE KITTENS explores life as the eldest daughter of a catholic teenage mother and all the contradictions that come along with being pro-choice and alive (against everyone's better judgment). From a white trash wedding to MTV’s 16 and Pregnant, Megan dives into all of the strange, hilarious details of her relationship with the woman who gave her life. <span><br/></span><span><br/></span>FREE KITTENS is fresh off a sold out run at Vancouver Fringe Festival & has a 5 star review in the Edmonton Journal,  Free Kittens is back this May at rEvolver Festival. <span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: 16+, miscarriage, animal hoarding, domestic abuse<span><br/></span><span><br/></span><span class=\"BoldText\">Talkback</span>: May 24<span><br/></span>
""";
  schema:startDate "2026-05-22T19:30:00"^^xsd:dateTime;
