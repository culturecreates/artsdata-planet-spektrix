<http://www.spektrix.com/thecultch/event/130001ASNPBJTQDQPGDNQTMRBPVHHPLCS> a schema:Event;
  schema:name "LIAM";
  schema:description """
	<span class=\"BoldText\">Elio Zarrillo</span><span><br/></span><span><br/></span>Jim Green House Studio 1885 Venables St.<span><br/></span><span><br/></span>They went out in search of a name, but found a body instead. <span><br/></span><span><br/></span>10 years after a brutal assault left them nameless, Dancing is trapped in the local Library for Broken Books, combing through grievances, manifestos, and silliness on a trial-by-fire fight for freedom from their own self. <span><br/></span><span><br/></span>Part warehouse party, part tattoo appointment, part philosophical chat on a long drive home, LIAM is a poetry-performance work in progress that, through vulnerability and care, invites us to truly be with our suffering. <span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: mentions of past sexual assault, surgery, blood & other bodily fluids, sex, drugs (specifically, cocaine) and the sometimes inevitable plight of being trans<span><br/></span><span><br/></span><span class=\"BoldText\">Talkback</span>: Following each performance<span><br/></span>
""";
  schema:startDate "2026-05-23T18:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/c173f58e-a434-4554-91cc-cf013394faf7.jpg>;
