<http://www.spektrix.com/thecultch/event/144202AMSTBJBBJMJNBRLRSJDSKLVDQMG> a schema:Event;
  schema:name "Reading: GEOMANCER";
  schema:description """
	<span class=\"BoldText\">Leslie Lum</span><span><br/></span><span><br/></span>Vancity Culture Lab 1895 Venables St.<span><br/></span><span><br/></span>Geomancer imagines a 1993 encounter between 82-year-old Chinese missile scientist Tsien Hsue-shen (钱学森)-deported from America during McCarthyism-and his 25-year-old Chinese American biographer, Iris Chang (張純如), who would later become a renowned human rights activist.<span><br/></span><span><br/></span>When Iris arrives in Beijing to interview Tsien, he refuses to cooperate. Obsessed with finding a new scientific revolution-one as transformative as quantum mechanics-Tsien turns to the metamorphosis of silkworms in search of the force the ancients called qi. But it is Iris who feels the peril of what connecting with that force might mean.<span><br/></span><span><br/></span>All <span class=\"BoldText\">rEvolver Festival readings</span> are by donation and <span class=\"BoldText\">100% of all donations go directly to the artists. </span><span><br/></span><span><br/></span>Donations start at a minimum of $5 (which comes to just under $9 after ticketing fees) and range up to $30. If you have more to give and would like to increase your donation, there is an option to do so at the checkout window.<span><br/></span><span><br/></span>Please note: readings cannot be booked with your festival pass.<span><br/></span><span><br/></span>Thank you for supporting emerging artists!<span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: None<span><br/></span><span><br/></span><span class=\"BoldText\">Talkback</span>: May 30.  There will be a short reception following the reading and talkback.
""";
  schema:startDate "2026-05-30T14:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/a4b64639-461d-4551-bbe5-a788a6acb6e0.jpg>;
  schema:location <https://spektrix.com/thecultch/location/801ARDQDDMGGJKKRTNTJBMCCMMBCPQKCR>;
  schema:offers _:8d3f42148ac64d7f9ac146ece797e2dc3186;
  schema:duration "PT75M";
  schema:endDate "2026-05-30T15:15:00"^^xsd:dateTime .

_:8d3f42148ac64d7f9ac146ece797e2dc3186 a schema:AggregateOffer;
  schema:lowPrice "5.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/thecultch/event/130601APHPQJHJPRKCMSLRCJTVSRDKMKQ> a schema:Event;
  schema:name "Reading: Oriental Cowboy Moshpit";
  schema:description """
	<span class=\"BoldText\">Garvin Chan</span><span><br/></span><span><br/></span>Jim Green House Studio 1885 Venables St.<span><br/></span><span><br/></span>In the Albertan Badlands there is a town with a pawn shop. In that pawn shop is a copy of Chinese family records thought to have been burned during the Cultural Revolution. <span><br/></span><span><br/></span>Now, it is up to a Chinese cowboy to retrieve those records in time to present them as part of their father’s funeral in this absurd, wacky, and strangely heartfelt heist play.<span><br/></span><span><br/></span>This is Oriental Cowboy Mosh Pit. <span><br/></span><span><br/></span>Yeehaw. <span><br/></span><span><br/></span>All <span class=\"BoldText\">rEvolver Festival readings</span> are by donation and <span class=\"BoldText\">100% of all donations go directly to the artists. </span><span><br/></span><span><br/></span>Donations start at a minimum of $5 (which comes to just under $9 after ticketing fees) and range up to $30. If you have more to give and would like to increase your donation, there is an option to do so at the checkout window.<span><br/></span><span><br/></span>Please note: readings cannot be booked with your festival pass.<span><br/></span><span><br/></span>Thank you for supporting emerging artists!<span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: Themes of violence, alcohol use<span><br/></span><span><br/></span><span class=\"BoldText\">Talkback</span>: May 31<span><br/></span>
""";
  schema:startDate "2026-05-31T14:15:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/92cf9d70-9808-45c7-b837-19c2db27c7b0.jpg>;
  schema:location <https://spektrix.com/thecultch/location/1201AQKTLDJVPVNVGVNTLHSSDPLSGRGBT>;
