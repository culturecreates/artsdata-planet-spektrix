  schema:duration "PT60M";
  schema:endDate "2026-10-15T20:30:00"^^xsd:dateTime .

_:c5a4b28f60d54d888edb71ae5e343b023551 a schema:AggregateOffer;
  schema:lowPrice "17.65";
  schema:priceCurrency "CAD" .

