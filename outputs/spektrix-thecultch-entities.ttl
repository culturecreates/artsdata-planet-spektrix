<http://www.spektrix.com/thecultch/event/138212AGVQBQNLGGCGPPSQMMMHQJMPKHN> a schema:Event;
  schema:name "Rogers v. Rogers — PREMIUM Presentation";
  schema:description """
	<span class=\"BoldText\">Premium Presentation</span><span><br/></span><span><br/></span><span class=\"BoldText\">Presented by The Cultch<span><br/></span>Produced by Crow’s Theatre (Toronto)</span><span><br/></span><span><br/></span>Adapted for the stage by Michael Healey, based on <span class=\"ItalicText\">Rogers v. Rogers: The Battle for Control of Canada’s Telecom Empire </span>by Alexandra Posadzki<span><br/></span><span><br/></span><span class=\"BoldText\">Directed by Chris Abraham</span><span><br/></span><span><br/></span>The York Theatre 639 Commercial Dr.<span><br/></span><span><br/></span>Telecom tycoon Ted Rogers built an empire, turning Canada’s airwaves into cash. Now his son Edward, long dismissed by his father, is fighting for control of the family business. Meanwhile, shrewd public servant Matthew Boswell is determined to derail Rogers’ billion-dollar takeover of Shaw Communications.<span><br/></span><span><br/></span>From award-winning playwright Micheal Healey (<span class=\"ItalicText\">The Master Plan, The Drawer Boy</span>) and starring Tom Rooney comes a play that examines the price of pushing back, the unravelling bonds of kin, and the legacy that money can—and cannot—buy.<span><br/></span>
""";
  schema:startDate "2027-01-19T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/b2d559e2-1886-4e6c-a455-ac6bac2b50d8.jpg>;
  schema:location <https://spektrix.com/thecultch/location/601APNNMRMBJQQPBSCNQGQHGKKCRPSSGN>;
  schema:offers _:8d3f42148ac64d7f9ac146ece797e2dc3195;
  schema:duration "PT60M";
  schema:endDate "2027-01-19T20:30:00"^^xsd:dateTime .

_:8d3f42148ac64d7f9ac146ece797e2dc3195 a schema:AggregateOffer;
  schema:lowPrice "17.65";
  schema:priceCurrency "CAD" .

