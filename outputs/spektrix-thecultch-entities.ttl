<http://www.spektrix.com/thecultch/event/138608ATRQKQJPRRPDDSVDJHHQRGLHPDG> a schema:Event;
  schema:name "The Effect";
  schema:description """
	<span class=\"BoldText\">Presented by The Cultch</span><span><br/></span><span class=\"BoldText\">Produced by Rumble Theatre (Vancouver) and ITSAZOO Productions (Vancouver)</span><span><br/></span><span><br/></span>Historic Theatre 1895 Venables St.<span><br/></span><span><br/></span>Connie and Tristan sign up for a clinical trial testing a new dopamine-regulating antidepressant under close observation. As doses increase, so does their attraction. But as desire intensifies and side effects ripple through the study, one unsettling question emerges: is this love… or just chemistry?<span><br/></span><span><br/></span>Placing audiences inside the clinical trial, the line between genuine emotion and chemical manipulation begins to blur. Provocative and darkly funny, <span class=\"ItalicText\">The Effect</span> asks: are we anything more than our brain chemistry? And if you can’t trust your heart or your mind… What’s left?<span><br/></span><span><br/></span>
""";
  schema:startDate "2026-10-23T19:30:00"^^xsd:dateTime;
