<http://www.spektrix.com/thecultch/event/137624AVHJBTKNKQKCRPTDQKNMTLLCBHD> a schema:Event;
  schema:name "Here Here:  Songs We Sing for Home";
  schema:description """
	<span class=\"BoldText\">Presented by The Cultch</span><span><br/></span><span class=\"BoldText\">Produced by Little Chamber Music (Vancouver)</span><span><br/></span><span class=\"BoldText\">Composed by Mishelle Cuttler and Molly MacKinnon</span><span><br/></span><span><br/></span>Historic Theatre 1895 Venables St.<span><br/></span><span><br/></span>A red fleece vest. A lover’s pillow. A rabbit in the snow. In <span class=\"ItalicText\">Here Here</span>, a selection of Vancouver writers contribute lyrics about their connection to the people, places, and things that make up home. Mishelle Cuttler and Molly MacKinnon have shaped these words into songs that are, in turn, poignant, sexy, and sometimes hilarious. From family histories to social anxieties, nature to migration, <span class=\"ItalicText\">Here Here</span> runs the gamut of story and style to offer a cohesive evening of reflections on ‘home’.
""";
  schema:startDate "2027-03-17T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/46a1f159-7382-476d-918f-a9f4607ba680.jpg>;
  schema:location <https://spektrix.com/thecultch/location/401ANPJQJQPQMRSBDNMVNLSPGTRBVQVRH>;
  schema:offers _:c5a4b28f60d54d888edb71ae5e343b023457;
  schema:duration "PT60M";
  schema:endDate "2027-03-17T20:30:00"^^xsd:dateTime .

