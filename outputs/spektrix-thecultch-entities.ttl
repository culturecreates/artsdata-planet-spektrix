<http://www.spektrix.com/thecultch/event/137807APSGLLQKKDVRNHHGKKGKGHQPJGK> a schema:Event;
  schema:name "Dirt";
  schema:description """
	<span class=\"BoldText\">Presented by The Cultch</span><span><br/></span><span class=\"BoldText\">Produced by Tentacle Tribe (Montreal)</span><span><br/></span><span><br/></span>Historic Theatre 1895 Venables St.<span><br/></span><span><br/></span>Transcending the boundaries between street and contemporary dance in a unique signature, <span class=\"ItalicText\">DIRT</span> is a striking piece for five virtuoso performers.<span><br/></span><span><br/></span>Through its raw expression, this creation is a critique of humanity’s conquering relationship with the planet. The quintet mixes puppets and movements in an unusual conceptual hip-hop. Choreographed by Elon Höglund, this work is a profound meditation on our ancestral connection with the Earth.<span><br/></span>
""";
  schema:startDate "2026-11-04T19:30:00"^^xsd:dateTime;
