<http://www.spektrix.com/thecultch/event/127801ALTVNTMHCKSBKGLQMQRJRQCJKNH> a schema:Event;
  schema:name "Reading:  Death is the Kindest";
  schema:description """
	<span class=\"BoldText\">Spencer McCairns</span><span><br/></span><span><br/></span>Jim Green House Studio 1885 Venables St.<span><br/></span><span><br/></span>Set in the immediate aftermath of a domestic terrorist attack on a queer nightclub in the United States, Death is the Kindest explores the themes of grief, love and family along the many paths that lead us through life. Torn by choice, a young queer woman must forage her own path through the afterlife and towards the end that she wants, and not the one being thrust upon her. <span><br/></span><span><br/></span>All <span class=\"BoldText\">rEvolver Festival readings</span> are by donation and <span class=\"BoldText\">100% of all donations go directly to the artists. </span><span><br/></span><span><br/></span>Donations start at a minimum of $5 (which comes to just under $9 after ticketing fees) and range up to $30. If you have more to give and would like to increase your donation, there is an option to do so at the checkout window.<span><br/></span><span><br/></span>Please note: readings cannot be booked with your festival pass.<span><br/></span><span><br/></span>Thank you for supporting emerging artists!<span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: Graphic depictions of violence against the queer community, death<span><br/></span><span><br/></span><span class=\"BoldText\">Talkback</span>: May 23<span><br/></span>
""";
  schema:startDate "2026-05-23T14:45:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/bf8ad4b0-80a2-4c01-a6ec-64e323dcc47f.jpg>;
  schema:location <https://spektrix.com/thecultch/location/1201AQKTLDJVPVNVGVNTLHSSDPLSGRGBT>;
  schema:offers _:ec4383dd32b74b0f85c637f958b321f82783;
  schema:duration "PT50M";
  schema:endDate "2026-05-23T15:35:00"^^xsd:dateTime .

_:ec4383dd32b74b0f85c637f958b321f82783 a schema:AggregateOffer;
  schema:lowPrice "5.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/thecultch/event/133001AJSRHDGHBBHJKMPKGHQCCNRTKJT> a schema:Event;
  schema:name "Reading: Above The Hospital";
  schema:description """
	<span class=\"BoldText\">Midtwenties Theatre & Beau Han Bridge</span><span><br/></span><span><br/></span>Jim Green House Studio 1885 Venables St.<span><br/></span><span><br/></span>In a cramped Vancouver apartment above a vet clinic, Lauren and Cameron navigate love, ambition, and the weight of unfulfilled dreams. Cameron chases a music career that never quite arrives. Lauren grapples with her own artistic aspirations while wondering if nursing school is the safer path. Over one explosive night that changes everything—and then twelve years later when the past comes knocking—they confront the gap between who they hoped to be and who they've become. A raw, intimate drama about the choices we make, the people we become, and whether passion alone is enough to survive on.<span><br/></span><span><br/></span>All <span class=\"BoldText\">rEvolver Festival readings</span> are by donation and <span class=\"BoldText\">100% of all donations go directly to the artists. </span><span><br/></span><span><br/></span>Donations start at a minimum of $5 (which comes to just under $9 after ticketing fees) and range up to $30. If you have more to give and would like to increase your donation, there is an option to do so at the checkout window.<span><br/></span><span><br/></span>Please note: readings cannot be booked with your festival pass.<span><br/></span><span><br/></span>Thank you for supporting emerging artists!<span><br/></span><span><br/></span><span class=\"BoldText\">Audience Advisory</span>: strong language, sexual content, substance use, discussions of grief and death, and mature themes related to relationships, mental health, and economic insecurity<span><br/></span><span><br/></span><span class=\"BoldText\">Talkback</span>: May 24<span><br/></span>
""";
  schema:startDate "2026-05-24T15:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/thecultch/files/13a1f4e0-6120-489d-9137-c299a1ff5224.jpg>;
  schema:location <https://spektrix.com/thecultch/location/1201AQKTLDJVPVNVGVNTLHSSDPLSGRGBT>;
  schema:offers _:ec4383dd32b74b0f85c637f958b321f82784;
  schema:duration "PT75M";
  schema:endDate "2026-05-24T16:45:00"^^xsd:dateTime .

