<http://www.spektrix.com/thecultch/event/126001ACMCHQKLPGTVRJNMSSRRJRCJGVB> a schema:Event;
  schema:name "In Conversation: Before the Show";
  schema:description """
	<h1> In Conversation: Before the Show</h1><h2>Presented by The Search Party</h2>Founders Lounge in the Historic Theatre<span><br/></span><span><br/></span><span><br/></span>This panel, presented in connection with People, Places & Things, is an open conversation about addiction and rehabilitation. <span><br/></span><span><br/></span>Guided by host Jeremy and joined by invited panelists Liza Huget and Aryn Mott, the discussion will draw from lived experience and reflection to explore the realities and complexities of recovery, with time reserved for audience questions and dialogue.<span><br/></span><span><br/></span>Book your complimentary seat now.<span><br/></span><span><br/></span><span class=\"ItalicText\">While there’s no cost to attend, donations for Westminster House’s Aboriginal programming will be gratefully accepted for those who feel moved to contribute. In-person donations can be made by debit, credit card, or cash at the event. </span><span><br/></span>
""";
  schema:startDate "2026-03-15T12:00:00"^^xsd:dateTime;
  schema:location <https://spektrix.com/thecultch/location/1401AHPQBSMRKMCGHQKGHVQVKCQNVNBKN>;
