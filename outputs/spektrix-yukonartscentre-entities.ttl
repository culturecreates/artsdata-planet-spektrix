<http://www.spektrix.com/yukonartscentre/event/71001AGBBMCNTJHLGBJRQPPQJJCSTSQBR>
  a schema:Event;
  schema:name "Nightswimming Theatre - These Are The Songs I Sing When I'm Sad";
  schema:description """
	<span class=\"ItalicText\">These Are The Songs That I Sing When I’m Sad</span> by Jane Miller and Brian Quirt is an intimate and joyous performance for one singer and an audience gathered around her piano. The show explores the songs people turn to when they’re sad, the songs that lift them out of sadness, and what makes listening to sad songs so addictive. <span><br/></span><span><br/></span>Part TED-talk, part house concert, join Jane as she shares the songs and stories that have impacted her life, and have the chance to share one of your songs with us. After each performance we publish a sad songs playlist generated by the audience members of that show. Check out the most recent playlists here from tours in Whitehorse, St. John’s, Vancouver, Victoria, and beyond: <a target=\"_blank\" href=\"https://nightswimming.ca/performance/these-are-the-songs-that-i-sing-when-im-sad/\">nightswimming.ca</a>
""";
  schema:startDate "2026-10-22T19:00:00"^^xsd:dateTime;
