<http://www.spektrix.com/yukonartscentre/event/69401AHRLMSBQLVDQNDHQJHGMBCGHMNBC>
  a schema:Event;
  schema:name "Moppets Childrens Festival: Gustavo the Impossiblist";
  schema:description """
	Gustavo the Impossibilist is a world-traveled, wildly unpredictable character performed by Dean Bareham, the Artistic Director and co-founder of Green Fools Theatre in Calgary. Described as a \"stunt clown\" and \"master of unrealized stupidity,\" Gustavo is a beloved fixture at international festivals and local Canadian events. Gustavo's act is a comedic blend of physical theatre, clowning, and stilt-walking. His performances are built around the hilariously \"impossible\" nature of his stunts.
""";
  schema:startDate "2026-06-06T15:00:00"^^xsd:dateTime;
