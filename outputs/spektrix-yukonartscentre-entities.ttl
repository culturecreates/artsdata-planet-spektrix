<http://www.spektrix.com/yukonartscentre/event/66801AQKPRHKKGQQBTMBVQVVTVMKKQTGN>
  a schema:Event;
  schema:name "All City Band: Sounds of Spring Celebration";
  schema:description """
	<h1>All-City Band: Sounds of Spring Celebration</h1><span><br/></span>The Sounds of Spring are in the air! Come join the All-City Band Society for a celebration of community music making on Monday, May 4th at the Yukon Arts Centre. <span><br/></span><span><br/></span>Show time 7pm, music in the lobby from 6:30pm and delicious baked goods & pop for sale during intermission. We have a wonderful program of favourites from the Concert & Jazz band repertoires to share with you, played by the students of Porter Creek & FH Collins Secondary Schools & our wonderful adult musicians! <span><br/></span><span><br/></span>Don’t forget to bring any donations you might have for the Food Bank; we can collect them & drop them off for you. Tickets: $20 (adults); $15 (students/seniors); & $10 (children under 12). For more information contact allcitybandwhitehorse@gmail.com or go to our Facebook page (@allcityband1) or our website (allcityband.com).<span><br/></span><span><br/></span>
""";
  schema:startDate "2026-05-04T19:00:00"^^xsd:dateTime;
