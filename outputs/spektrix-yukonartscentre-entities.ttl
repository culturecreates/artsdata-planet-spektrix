  a schema:Event;
  schema:name "SIAKOL CANADA TOUR 2026";
  schema:description """
	<span class=\"BoldText\">Siakol Live in Whitehorse Canada 2026 – The Rock N’ Roll Reunion Tour</span><span><br/></span><span><br/></span>Get ready, <span class=\"BoldText\">WHITEHORSE!</span> The legendary Filipino rock band <span class=\"ItalicText\"><span class=\"BoldText\">Siakol</span></span> is hitting the road for their much-awaited <span class=\"BoldText\">2026 World Tour</span>, bringing their signature Pinoy rock anthems and high-energy performances to Filipino communities across the country.<span><br/></span><span><br/></span>Sing along to timeless hits like <span class=\"ItalicText\">“Lakas-Tama”</span>, <span class=\"ItalicText\">“Peksman”</span>, and <span class=\"ItalicText\">“Bakit ba?”</span> as Siakol delivers a night of nostalgia, fun, and pure rock ‘n’ roll spirit.<span><br/></span><span><br/></span>Join us for an unforgettable concert experience that celebrates friendship, music, and homegrown Pinoy talent — live and loud in Whitehorse, Yukon, Canada!<span><br/></span><span><br/></span><span class=\"BoldText\">Siakol Live in WHITEHORSE, CANADA 2026 — Tara, sabay tayong magwala!</span><span><br/></span>
""";
