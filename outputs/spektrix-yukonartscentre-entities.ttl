<http://www.spektrix.com/yukonartscentre/event/67601AVHPCSTMMBKTGKLCGLQQCGMMBVSK>
  a schema:Event;
  schema:name "Yukon Community Choirs Present: Changes";
  schema:description """
	<h2>Yukon Community Choirs presents their annual spring showcase: Changes. </h2>This performance features choral music across genres performed by one or more of the five choirs: Confluence Chorus, Persephone Singers, The Neptunes, Alluvia Voices, and introducing the Yukon Youth Choir. Under the direction of Nick Turnbull, Maxime Crawford-Holland, and C.D. Saint, and accompaniment by Cheryl Wishart, Ben Johnston-Urey and Cate Innish, the Yukon Community Choirs will guide the audience through choral reflections on change; in our world, our community and ourselves. We invite you to open yourself to an evening of Changes.
""";
  schema:startDate "2026-05-01T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/yukonartscentre/files/f7f825d7-2e7b-4d50-b157-0a55f5c4a06b.jpg>;
