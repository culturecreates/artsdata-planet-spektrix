<http://www.spektrix.com/ticketseller/event/47001AKGBPVRNLLTLGMHBTDTNRJQVNRCM> a schema:Event;
  schema:name "OSO - Music That Shimmers";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
