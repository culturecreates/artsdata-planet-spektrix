<http://www.spektrix.com/tarragontheatre/event/46201AMLCVHRCMSRMCBPBJCBDJSGKTGPC>
  a schema:Event;
  schema:name " CRIPtonite (Guest Presentation)";
  schema:description """
	<span class=\"BoldText\">The Disability Collective</span> is thrilled to present <span class=\"ItalicText\">CRIPtonite</span>, a Deaf and disability-led drag and burlesque show! <span><br/></span><span><br/></span><span class=\"ItalicText\">CRIPtonite</span> brings together a variety of talented performers to celebrate the intersectionality of queer and disabled identities! We’re challenging barriers and showcasing the incredible artistry in our community. Expect a night of fierce creativity, radical accessibility, and unapologetic self-expression.<span><br/></span><span><br/></span>Tickets are available in a Pay-What-You-Can format.<span><br/></span><span><br/></span>Join us in-person at Tarragon Theatre or online via livestream on Saturday, August 8th at 8 PM for a line up of bold and boundary-pushing acts.<span><br/></span><span><br/></span><span class=\"UnderlineText\">There are two options to enjoy this performance:</span><span><br/></span>Join us <span class=\"BoldText\">IN PERSON</span>! This is a Mask Required, ASL Interpreted, and Audio Described event.<span><br/></span><span><br/></span>Join us for a <span class=\"BoldText\">LIVESTREAM</span>! You will receive a link on the day of the performance. This is an ASL Interpreted and Audio Described event.<span><br/></span><span><br/></span><span class=\"ItalicText\">If you have any accessibility needs please contact Patron Services: patronservices@tarragontheatre.com or call us at 416-531-1827.</span>
""";
  schema:startDate "2026-08-08T20:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/tarragontheatre/files/f7029710-415c-4ea1-9c3b-8998ffde4d2e.jpg>;
  schema:location <https://spektrix.com/tarragontheatre/location/801ARDQDDMGGJKKRTNTJBMCCMMBCPQKCR>;
  schema:organizer <https://spektrix.com/tarragontheatre/organization/tarragon-theatre>;
  schema:offers _:57e8ee661ad740a08e5ad0ea20bc4b346529;
  schema:duration "PT135M";
  schema:endDate "2026-08-08T22:15:00"^^xsd:dateTime .

