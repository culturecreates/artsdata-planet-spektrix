<http://www.spektrix.com/tarragontheatre/event/46401AJJTJHQJSQQVGTKDVGHPLJJBLHMJ>
  a schema:Event;
  schema:name "Dial 1 for UK (Guest Presentation)";
  schema:description """
	<h1>Dial 1 for UK</h1><h2>Produced by The Disability Collective </h2><span><br/></span>Writer and Performer: Mohit Mathur<span><br/></span>Director: Phil Willmott<span><br/></span>Assistant Director: Ralph Jefferys<span><br/></span>Dramaturg: Dhanu Chinniah<span><br/></span>Stage Manager: Scarlett Larry<span><br/></span>Lighting Designer: Rachel Sampley<span><br/></span>Set Designer: Caitlin Abbott<span><br/></span>Sound Designer: Ansuman Biswa<span><br/></span><span><br/></span><span class=\"ItalicText\">Age Recommendation: 12+, Content warning: References to racism, immigration-related trauma, and mental health struggles.</span><span><br/></span><span><br/></span>Get ready for the Canadian premiere of <span class=\"ItalicText\">Dial 1 for UK</span>, arriving fresh off its critically acclaimed national UK tour. Written and performed by rising West End star Mohit Mathur (Life of Pi) and directed by Phil Willmott, this award-winning production is a masterclass in solo performance, packed with vibrant energy, sharp wit, and unexpected depth.<span><br/></span><span><br/></span>Follow Uday, an optimistic call-center agent in New Delhi who dreams of an idealized British life filled with fish, chips, and tea with the royals. But when he seizes a chance opportunity to fly to England, his glossy YouTube fantasy collides with the real-world path of an everyday worker in the UK care sector. What unfolds is a rich, beautifully human story of high hopes, digital illusions, and the quiet reality of navigating a new world.<span><br/></span><span><br/></span>Propelled by Mathur’s magnetic charisma and fast-paced humor, <span class=\"ItalicText\">Dial 1 for UK</span> is a brilliant piece of storytelling.<span><br/></span><span><br/></span>Come see the show international critics are raving about:<span><br/></span><span><br/></span>★★★★★ <span class=\"ItalicText\">\"Sometimes you're lucky enough to stumble upon a little gem, and this was a polished diamond.\"</span> — Green Room Reviews<span><br/></span><span><br/></span>★★★★★ <span class=\"ItalicText\">“It’s a true tour-de-force performance from Mohit Mathur.\"</span> — The Real Chrisparkle<span><br/></span><span><br/></span>★★★★ <span class=\"ItalicText\">\"…candid, heartwarming, and at times challenging…\"</span> — Northern Arts Review<span><br/></span>
""";
  schema:startDate "2026-09-10T20:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/tarragontheatre/files/b5cc23b0-664b-4298-b43a-cec2b5b67543.jpg>;
  schema:location <https://spektrix.com/tarragontheatre/location/801ARDQDDMGGJKKRTNTJBMCCMMBCPQKCR>;
  schema:organizer <https://spektrix.com/tarragontheatre/organization/tarragon-theatre>;
  schema:offers _:57e8ee661ad740a08e5ad0ea20bc4b346584;
  schema:duration "PT60M";
  schema:endDate "2026-09-10T21:00:00"^^xsd:dateTime .

_:57e8ee661ad740a08e5ad0ea20bc4b346584 a schema:AggregateOffer;
  schema:url <https://purchase.tarragontheatre.com/EventAvailability?EventId=16801&ref=bookNow&scroll=timeAndDates>;
  schema:lowPrice "10.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/tarragontheatre/event/46402ARRKJRKJHHPQLVSCRLVRGHNKBCSK>
  a schema:Event;
  schema:name "Dial 1 for UK (Guest Presentation)";
  schema:description """
	<h1>Dial 1 for UK</h1><h2>Produced by The Disability Collective </h2><span><br/></span>Writer and Performer: Mohit Mathur<span><br/></span>Director: Phil Willmott<span><br/></span>Assistant Director: Ralph Jefferys<span><br/></span>Dramaturg: Dhanu Chinniah<span><br/></span>Stage Manager: Scarlett Larry<span><br/></span>Lighting Designer: Rachel Sampley<span><br/></span>Set Designer: Caitlin Abbott<span><br/></span>Sound Designer: Ansuman Biswa<span><br/></span><span><br/></span><span class=\"ItalicText\">Age Recommendation: 12+, Content warning: References to racism, immigration-related trauma, and mental health struggles.</span><span><br/></span><span><br/></span>Get ready for the Canadian premiere of <span class=\"ItalicText\">Dial 1 for UK</span>, arriving fresh off its critically acclaimed national UK tour. Written and performed by rising West End star Mohit Mathur (Life of Pi) and directed by Phil Willmott, this award-winning production is a masterclass in solo performance, packed with vibrant energy, sharp wit, and unexpected depth.<span><br/></span><span><br/></span>Follow Uday, an optimistic call-center agent in New Delhi who dreams of an idealized British life filled with fish, chips, and tea with the royals. But when he seizes a chance opportunity to fly to England, his glossy YouTube fantasy collides with the real-world path of an everyday worker in the UK care sector. What unfolds is a rich, beautifully human story of high hopes, digital illusions, and the quiet reality of navigating a new world.<span><br/></span><span><br/></span>Propelled by Mathur’s magnetic charisma and fast-paced humor, <span class=\"ItalicText\">Dial 1 for UK</span> is a brilliant piece of storytelling.<span><br/></span><span><br/></span>Come see the show international critics are raving about:<span><br/></span><span><br/></span>★★★★★ <span class=\"ItalicText\">\"Sometimes you're lucky enough to stumble upon a little gem, and this was a polished diamond.\"</span> — Green Room Reviews<span><br/></span><span><br/></span>★★★★★ <span class=\"ItalicText\">“It’s a true tour-de-force performance from Mohit Mathur.\"</span> — The Real Chrisparkle<span><br/></span><span><br/></span>★★★★ <span class=\"ItalicText\">\"…candid, heartwarming, and at times challenging…\"</span> — Northern Arts Review<span><br/></span>
""";
  schema:startDate "2026-09-11T20:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/tarragontheatre/files/b5cc23b0-664b-4298-b43a-cec2b5b67543.jpg>;
