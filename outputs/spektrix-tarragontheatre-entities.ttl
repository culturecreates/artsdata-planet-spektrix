<http://www.spektrix.com/tarragontheatre/event/27201ATMPGJCKNGLLLPMRKRVCVBLCMPLH>
  a schema:Event;
  schema:name "Agency (Tarragon X TMU)";
  schema:description """
	<h1>Agency</h1>written by Nathaniel Hanula-James<span><br/></span>dramaturgy and direction by Mariló Núñez<span><br/></span><span><br/></span>In the heady days of 2019, a queer-owned ad agency strives to make a pride campaign for a meal kit company. But the client is capricious; the office is awash in romance and rivalry; and as for the janitor… That’s a whole other story. <span class=\"ItalicText\">Agency</span> is a chaotic screwball comedy for our precarious times. <span><br/></span><span><br/></span><span><br/></span><h2>Tarragon x TMU</h2>Performance at The Creative School and Tarragon Theatre collaborate on two workshop projects which support the development of new work, featuring the graduating class of Performance Acting students.<span><br/></span><span><br/></span><span class=\"BoldText\">Please Note:</span> <span class=\"ItalicText\">Agency</span> includes some sensitive themes, if you want to know more, <a target=\"_top\" href=\"https://tarragontheatre.com/plays/uncategorized/tarragonxtmu/\">visit our website.</a>
""";
  schema:startDate "2025-11-19T19:30:00"^^xsd:dateTime;
