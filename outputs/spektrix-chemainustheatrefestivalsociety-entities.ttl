<http://www.spektrix.com/chemainustheatrefestivalsociety/event/31401ACGSQBSNGJMMSMSJDBKPVTCCSKMC>
  a schema:Event;
  schema:name "Backstage Tour - Donor Event";
  schema:description """
	<h2><span class=\"BoldText\">Exclusive Backstage Tour for $250+ Donors</span></h2><span><br/></span>We’re opening the doors to a behind‑the‑scenes experience at Chemainus Theatre. This in‑person backstage tour is offered only four times this year and is exclusively available to donors who have given $250+ in the past year.<span><br/></span><span><br/></span>Guests will be guided through areas of the theatre not typically open to the public, gaining a closer look at how productions come together and what happens beyond the stage lights. With very limited capacity, each tour is designed to feel personal, relaxed, and special - a small way for us to thank you for the support that keeps our work thriving. We can’t wait to share this inside look with you. <span><br/></span><span><br/></span>Approximate Length: 30 minutes<span><br/></span>
""";
  schema:startDate "2026-05-14T17:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chemainustheatrefestivalsociety/files/85ab580e-967b-4347-adb9-cd78cf0fe560.jpg>;
  schema:location <https://spektrix.com/chemainustheatrefestivalsociety/location/403ASKCQMVCSKPPLNQMQPJVVSRPGMSKLR>;
  schema:offers _:cab21ce75f7f43899f29f24336be7ed85994;
  schema:duration "PT30M";
  schema:endDate "2026-05-14T17:30:00"^^xsd:dateTime .

_:cab21ce75f7f43899f29f24336be7ed85994 a schema:AggregateOffer;
  schema:lowPrice "0.0";
