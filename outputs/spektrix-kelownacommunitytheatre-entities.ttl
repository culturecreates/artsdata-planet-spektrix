  a schema:Event;
  schema:name "The Road Hammers Boots on the Beach Concert";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
			<td align=\"left\" colspan=\"1\"><img src=\"https://system.spektrix.com/kelownacommunitytheatre/files/ff143161-46c3-4e12-9641-d1194be4a3f4.jpg\" /> </td><td align=\"left\"><h2>Leavitt Machinery presents </h2><h1><span class=\"UnderlineText\">THE ROAD HAMMERS</span></h1></td>
		</tr>
	</table><span><br/></span><h2>TOUCHDOWN KELOWNA BOOTS ON THE BEACH CONCERT</h2><h2><span class=\"ItalicText\">with special guest Jese Lawrence</span></h2><span><br/></span>Country meets coastline at <span class=\"ItalicText\"><span class=\"BoldText\">Boots on the Beach</span></span>, an outdoor summer concert on Kelowna’s waterfront featuring <span class=\"ItalicText\"><span class=\"BoldText\">The Road Hammers</span></span>, with special guest <span class=\"ItalicText\"><span class=\"BoldText\">Jese Lawrence</span></span>.<span><br/></span><span><br/></span>Close out the festival with a high-energy, full‑production country rock show on a waterfront stage, surrounded by thousands of fans, stadium sound, and peak summer vibes. Expect loud guitars, cold drinks, and a beach‑party atmosphere you won’t forget.<span><br/></span><span><br/></span>This all‑ages event offers lawn seating with food trucks, beverage service, and a full-site liquor licence. Bring a folding chair or blanket and settle in for one of Kelowna’s biggest summer concerts.<span><br/></span><span><br/></span><span class=\"BoldText\">Boots on. Volume up. Meet us on the beach.</span><span><br/></span><span><br/></span><span class=\"BoldText\">Additional Information:</span><span><br/></span><ul><li> <span class=\"BoldText\">All‑ages outdoor concert</span></li><li> <span class=\"BoldText\">Gates open:</span> 7 pm</li><li> <span class=\"BoldText\">Seating:</span> General admission lawn (bring a chair or blanket)</li><li> <span class=\"BoldText\">Amenities:</span> Food trucks, bar service, full site liquor licence</li><li> <span class=\"BoldText\">Location:</span> Waterfront Festival Site, Kelowna</li></ul><span class=\"BoldText\">Concert Bundle Offer:</span><span><br/></span>Attending both headline shows? Purchase tickets to the Kickoff Concert featuring Alan Doyle and Boots on the Beach with The Road Hammers to receive a discounted bundle rate automatically at checkout.<span><br/></span><span><br/></span><span class=\"BoldText\">About The Road Hammers:</span><span><br/></span><a target=\"_blank\" href=\"https://www.theroadhammers.ca/\">theroadhammers.ca</a><span><br/></span><span><br/></span><span class=\"BoldText\">About Jese Lawrence:</span><span><br/></span><a target=\"_blank\" href=\"https://jeselawrencemusic.com/\">jeselawrencemusic.com</a><span><br/></span>---<span><br/></span><h2>Pricing</h2><ul><li><span class=\"BoldText\">VIP Admission $144.90</span>  ($126.00 base price + $18.90 service charge)</li><li><span class=\"BoldText\">General Admission  $72.45</span>  ($63.00 base price + $9.45 service charge)</li><li><span class=\"BoldText\">Children 12 and under - General Admission  $50.72</span>  ($44.10 base price + $6.62 service charge)</li><li><span class=\"BoldText\">Children 5 and under - General Admission are free</span></li></ul><span><br/></span><span class=\"BoldText\">Concert Bundle Offer:</span><span><br/></span><ul><li>General Admission Kickoff + General Admission Boots on the Beach = <span class=\"BoldText\">$21.00 savings</span></li><li>VIP Kickoff + VIP Boots on the Beach = <span class=\"BoldText\">$42.00 savings</span></li><li><span class=\"ItalicText\">Ticket types must match. Discount applies automatically at checkout, no promo code needed.</span></li></ul><span><br/></span><span class=\"BoldText\">VIP Tickets include special VIP area with a private bar and washrooms.</span><span><br/></span><span><br/></span><span class=\"ItalicText\"><span class=\"BoldText\">The event will proceed rain or shine.</span></span><span><br/></span><span><br/></span><span class=\"ItalicText\">All above prices are in CAD and include GST.</span><span><br/></span><span><br/></span>---<span><br/></span><span><br/></span><span class=\"ItalicText\">A service fee is added for box office costs, card processing, and taxes. Tickets for <span class=\"BoldText\">THE ROAD HAMMERS BOOTS ON THE BEACH CONCERT</span> and their applicable service fees are non-refundable.</span>
""";
