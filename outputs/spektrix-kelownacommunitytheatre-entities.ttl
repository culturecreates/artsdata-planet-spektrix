<http://www.spektrix.com/kelownacommunitytheatre/event/338001AQGSTCRCMVRPGTLRSLCNNPRQGJJ>
  a schema:Event;
  schema:name "Henry Sir Live in Kelowna";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
			<td align=\"left\" colspan=\"1\"><img src=\"https://system.spektrix.com/kelownacommunitytheatre/files/a823d1d2-eae7-477c-b713-3a1b8cf6579b.jpg\" /> </td><td align=\"left\"><h1><span class=\"UnderlineText\">HENRY SIR LIVE IN KELOWNA</span></h1></td>
		</tr>
	</table><span><br/></span><span class=\"ItalicText\"><span class=\"BoldText\">Audience advisory: Ages 19+ only, adult language</span></span><span><br/></span><span><br/></span>Henry Sir is an All-Canadian basketball player turned comedian and writer. Born and raised in Edmonton, Alberta, he’s spent the last years in New York where he performs at the top clubs in the city like The Comedy Cellar and Gotham Comedy Club while touring North America. He’s been featured on Comedy Central, Just For Laughs New Faces, Don’t Tell Comedy, and CBC New Wave of Stand Up. Henry is the host of the satirical political podcast, The Freedom Hour, and the popular social media series, Current Events Chirped By A Canadian.<span><br/></span><span><br/></span><h2>Pricing</h2><span class=\"BoldText\">Regular  $38.94</span>  ($31.50 base price + $2.36 CIF + $5.08 service charge)<span><br/></span><span><br/></span><span class=\"ItalicText\">All above prices are CAD and include GST.</span><span><br/></span><span><br/></span>---<span><br/></span><span><br/></span><span class=\"ItalicText\">Mary Irwin Theatre at the Rotary Centre for the Arts event tickets include a $2.36 Capital Improvement Fee (CIF). A service fee is added for box office costs, card processing, and taxes. <span class=\"BoldText\">Henry Sir Live in Kelowna</span> tickets and their applicable fees are non-refundable.</span>
""";
