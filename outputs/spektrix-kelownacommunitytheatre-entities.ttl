  a schema:Event;
  schema:name "Ivan Decker";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
			<td align=\"left\" colspan=\"1\"><img src=\"https://system.spektrix.com/kelownacommunitytheatre/files/271b0ea8-48e2-4abe-bcd4-44b810aea1d3.jpg\" /> </td><td align=\"left\"><h2>Just For Laughs VANCOUVER presents </h2><h1><span class=\"UnderlineText\">IVAN DECKER</span></h1></td>
		</tr>
	</table><span><br/></span><h2>This is an all‑ages event.</h2><span class=\"BoldText\">Vancouver’s own Ivan Decker is an award-winning stand-up comedy powerhouse, recognized as one of the best in the country.</span><span><br/></span><span><br/></span>His sharp wit and impeccable timing have earned him a JUNO Award win, a Netflix half-hour special, and appearances on CBC, CTV, TBS, CONAN, The Debaters, and Just For Laughs, along with headlining spots at festivals across North America and Europe. Chortle Magazine UK calls his comedy “smart, original, and slick,” and we couldn’t agree more — Just For Laughs VANCOUVER is proud to present Ivan Decker live across Western Canada.<span><br/></span><span><br/></span><h2>Pricing</h2><span class=\"BoldText\">Regular  $44.69</span>  ($36.50 base price + $2.36 CIF + $5.83 service charge)<span><br/></span><span><br/></span><span class=\"ItalicText\">All above prices are CAD and include GST.</span><span><br/></span><span><br/></span>---<span><br/></span><span><br/></span><span class=\"ItalicText\">Mary Irwin Theatre at the Rotary Centre for the Arts event tickets include a $2.36 Capital Improvement Fee (CIF). A service fee is added for box office costs, card processing, and taxes. <span class=\"BoldText\">Ivan Decker</span> tickets and their applicable fees are non-refundable.</span>
""";
