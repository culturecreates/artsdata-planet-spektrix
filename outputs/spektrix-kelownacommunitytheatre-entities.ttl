<http://www.spektrix.com/kelownacommunitytheatre/event/384202AHDSRCPDGRDRSTMJSNDPMCGBCNR>
  a schema:Event;
  schema:name "Hokus Pokus Live! - RIP (Really Important Person) Upgrade Package";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
			<td align=\"left\"><h2>Hokus Pokus Live!</h2><h1><span class=\"UnderlineText\">RIP (REALLY IMPORTANT PERSON) PACKAGE UPGRADE</span></h1></td>
		</tr>
