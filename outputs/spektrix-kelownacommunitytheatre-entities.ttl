<http://www.spektrix.com/kelownacommunitytheatre/event/288601ANKDTLNSQPSCBDBRCDCBDLKTDJC>
  a schema:Event;
  schema:name "U4 - An Epic Evening of U2";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
			<td align=\"left\" colspan=\"1\"><img src=\"https://system.spektrix.com/kelownacommunitytheatre/files/d168d709-c5e4-4433-878e-aa6ed5f8584b.jpg\" /> </td><td align=\"left\"><h2>BMR Entertainment presents</h2><h1><span class=\"UnderlineText\">U4</span> </h1><span class=\"ItalicText\"><span class=\"BoldText\">An Epic Evening of U2</span></span><span><br/></span></td>
		</tr>
	</table><span><br/></span><span><br/></span>U2  By  U4 .  NOT JUST ANOTHER CLASSIC ROCK SHOW. APRIL 2nd, It's an epic evening of high highs and deep emotion at the Rotary Center For The Arts. Featuring members of Canada’s Trooper, you receive the complete U2 experience, from the legendary ‘Joshua Tree’ period to ‘How To Dismantle An Atomic Bomb’, all eras are covered with equal attention to detail. U4 is not just incredible musicians, but a theatrical experience which engages, and captivates audiences, U4 is a must see show for all music lovers.<span><br/></span><span><br/></span><h2>Pricing</h2><span class=\"BoldText\">Regular  $49.95</span>  ($41.07 base price + $2.36 CIF + $6.52 service charge)<span><br/></span><span><br/></span><span class=\"ItalicText\">All above prices are CAD and include GST.</span><span><br/></span><span><br/></span>---<span><br/></span><span><br/></span><span class=\"ItalicText\">Mary Irwin Theatre at the Rotary Centre for the Arts event tickets include a $2.36 Capital Improvement Fee (CIF). A service fee is added for box office costs, card processing, and taxes. <span class=\"BoldText\">U4 - An Epic Evening of U2</span> tickets and their applicable fees are non-refundable.</span>
""";
