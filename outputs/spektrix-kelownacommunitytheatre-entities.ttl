  a schema:Event;
  schema:name "Love Lost and Love Found";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
			<td align=\"left\" colspan=\"1\"><img src=\"https://system.spektrix.com/kelownacommunitytheatre/files/f3ef1624-495f-40fb-bba5-6ac0767fda05.jpg\" /> </td><td align=\"left\"><h2>World Financial Group presents</h2><h1><span class=\"UnderlineText\">LOVE LOST AND LOVE FOUND</span></h1></td>
		</tr>
	</table><span><br/></span>UpStage Kelowna Show Choir is thrilled to present Love Lost & Love Found - featuring a fantastic variety of Broadway, pop, and movie musical songs that will take the audience through the highs and lows of love. With musical selections from Hello, Dolly, Pitch Perfect, and Dreamgirls, to songs by Meghan Trainer, Coldplay, and Adele, UpStage blends their love of choral singing and choreographed dance in a spectacular, must-see performance!<span><br/></span><span><br/></span>---<span><br/></span><span><br/></span><h2>Pricing</h2><span><br/></span><span class=\"BoldText\">Adult. $30.00</span>  ($23.73 base price + $2.36 CIF + $3.91 service charge)<span><br/></span><span class=\"BoldText\">Student w/ID. $25.00</span>  ($19.39 base price + $2.36 CIF + $3.26 service charge)<span><br/></span><span class=\"BoldText\">Senior  $25.00</span> ($19.39 base price + $2.36 CIF + $3.26 service charge)<span><br/></span><span class=\"BoldText\">Children under 5 are free, pre-registration is required.</span><span><br/></span><span><br/></span><span class=\"ItalicText\">All above prices are CAD and include GST.</span><span><br/></span><span><br/></span>---<span><br/></span><span><br/></span><span class=\"ItalicText\">Mary Irwin Theatre at the Rotary Centre for the Arts event tickets include a $2.36 Capital Improvement Fee (CIF). A service fee is added for box office costs, card processing, and taxes. <span class=\"BoldText\">Love Lost and Love Found</span> tickets and their applicable fees are non-refundable.</span>
""";
