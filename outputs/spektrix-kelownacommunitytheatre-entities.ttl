<http://www.spektrix.com/kelownacommunitytheatre/event/310401ALGSPCCJQLNPSDSRMCKKPKCLKVK>
  a schema:Event;
  schema:name "ABBA Euphoria";
  schema:description """
	<table class=\" BorderOn\">
		<tr>
			<td align=\"left\" colspan=\"1\"><img src=\"https://system.spektrix.com/kelownacommunitytheatre/files/1a2978ec-45ce-4066-8160-07df3296b0f2.jpg\" /> </td><td align=\"left\"><h2>Vegas Show Bands presents </h2><h1><span class=\"UnderlineText\">ABBA EUPHORIA</span></h1></td>
		</tr>
	</table><span><br/></span><span><br/></span>ABBA EUPHORIA - America's Favorite ABBA SHOW!<span><br/></span><span><br/></span>Get Ready for ABBA EUPHORIA - An Uplifting and Euphoric ABBA TRIBUTE SHOW straight from the bright lights of Las Vegas!!<span><br/></span><span><br/></span>This energizing LIVE CONCERT is enhanced by a Stunning Full Length On-Screen Media Show and is Super Fun for all ages!!<span><br/></span><span><br/></span>The tour spans across Nevada, Florida, Texas, Colorado, Utah and now they are bringing their exciting show to Canada! <span><br/></span><span><br/></span>Prepare to sing your heart out at this interactive concert and get totally euphoric with ABBA's timeless hits like \"Dancing Queen,\" \"The Winner Takes it All,\" \"Mamma Mia,\" \"SOS,\" \"Waterloo,\" \"Super Trouper,\" and so many more!!<span><br/></span><span><br/></span>ABBA EUPHORIA brings the mega hits, the cheer, the choreography, the fun times, and get ready for a few disco surprises!!<span><br/></span><span><br/></span><h2>Pricing</h2><span class=\"BoldText\">Regular $60.21</span>  ($50.00 base price + $2.36 CIF + $7.85 service charge)<span><br/></span><span><br/></span><span class=\"BoldText\">$5 off Early Bird promotion* available until March 30th!</span><span><br/></span><span><br/></span><span class=\"ItalicText\">All above prices are in CAD and include GST.</span><span><br/></span><span><br/></span>---<span><br/></span><span><br/></span><span class=\"ItalicText\">Mary Irwin Theatre at the Rotary Centre for the Arts event tickets include a $2.36 Capital Improvement Fee (CIF). A service fee is added for box office costs, card processing, and taxes. <span class=\"BoldText\">ABBA Euphoria</span> tickets and their applicable fees are non-refundable.</span>
""";
