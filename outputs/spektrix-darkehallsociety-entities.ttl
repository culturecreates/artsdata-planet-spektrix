<http://www.spektrix.com/darkehallsociety/event/36201ASKGPVLCNJNCMBLVSLJHKQPCHTRV>
  a schema:Event;
  schema:name "Darke Hall Presents Series 26/27 Season Launch";
  schema:description """
	<h1>A New Season Is Coming</h1><span><br/></span>Our 26/27 season will be announced May 27—and newsletter subscribers get the first look.<span><br/></span><span><br/></span>We’ve been building this season with you in mind. Expect exciting names, unforgettable performances, and new experiences that bring artists and audiences closer together. With new pricing options designed to keep things flexible and accessible, it’s easy to be part of it - whether you’re a longtime friend or just joining us.<span><br/></span><span><br/></span>It’s a season shaped by community, curiosity, and connection, and we can’t wait to share it with you first.<span><br/></span><span><br/></span><span class=\"BoldText\"><a href=\"https://purchase.darkehall.ca/Signup\">Sign up here!</a></span>
""";
  schema:startDate "2026-05-27T09:00:00"^^xsd:dateTime;
