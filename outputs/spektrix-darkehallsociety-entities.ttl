<http://www.spektrix.com/darkehallsociety/event/28001ATQBPNCNMQQVMPLRVTJTQRGHDNSG>
  a schema:Event;
  schema:name "Cinderella";
  schema:description """
	<span class=\"BoldText\">Rodgers & Hammerstein’s Cinderella, Enchanted Edition</span> is a charming stage musical that brings the classic fairy tale of Cinderella to life with lively songs, colorful costumes, and heartfelt moments.  The story follows Cinderella as she overcomes hardship with kindness and courage, helped along the way by a touch of magic.  Filled with humor, romance, and uplifting music, the show celebrates believing in yourself and the power of dreams coming true.<span><br/></span><span><br/></span><span class=\"ItalicText\">Tickets are $26.25 for adults, or $15.75 for youth 17 & under (prices include fees and taxes). Seating is assigned.</span>
""";
  schema:startDate "2026-05-20T19:00:00"^^xsd:dateTime;
