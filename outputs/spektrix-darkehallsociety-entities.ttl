<http://www.spektrix.com/darkehallsociety/event/26601APLTNSPSGDPBRQVGGSRDMVBVVNQK>
  a schema:Event;
  schema:name "Cecilian Chamber Series Artist Dinner & Fundraiser";
  schema:description """
	Join the <span class=\"BoldText\">Cecilian Chamber Series</span> for an Artist Dinner & Fundraiser with the <span class=\"BoldText\">Milatz-Crozman Duo and James Campbell</span> on Sunday, April 12th following their 3 pm concert.  Experience a three-course dinner at Memories Fine Dining (1717 Victoria Avenue) followed by an interview with the artists.<span><br/></span><span><br/></span><span class=\"ItalicText\">Single tickets are $140 each ($75 tax receipt).<span><br/></span><span><br/></span>Deadline for ticket purchases is April 1, 2026.  Limited seating is available.</span><span><br/></span>
""";
