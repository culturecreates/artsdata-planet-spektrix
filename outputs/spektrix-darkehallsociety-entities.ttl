  a schema:Event;
  schema:name "Collective Studios Summer Showcase";
  schema:description """
	<span class=\"BoldText\">Collective Studios</span> is a dance studio for adults that offers drop-in classes and performance sessions in a variety of styles and levels.  Join them for their <span class=\"BoldText\">9th Showcase</span> and enjoy an evening of show stopping dance routines by their students, instructors, companies, and special invited guests!  Featuring styles such as Tap, Jazz, Hip Hop, Ballet, Salsa, Contemporary, Heels, Soca, and so much more.  It is always a night to remember!<span><br/></span><span><br/></span><span class=\"ItalicText\">Tickets are $30 inclusive of fees and taxes.  Seating is assigned.</span><span><br/></span><span><br/></span><span class=\"ItalicText\">All sales are final; no refunds issued.</span>
""";
