<http://www.spektrix.com/darkehallsociety/event/9801ASMPJNGDQLTQPCPCCHKQQRGTTRTJM>
  a schema:Event;
  schema:name "A World Transformed";
  schema:description """
	<span class=\"BoldText\">A World Transformed</span> is a unique performance that weaves together live music, dance, and spoken word to tell the stories of Matthew and Judy Shepard. Produced by Echo Chamber and choreographed by acclaimed Canadian dance makers William Yong and Laurence Lemieux, <span class=\"ItalicText\">A World Transformed</span> is a deeply moving performance that explores profound grief while inspiring hope in the transformative power of every individual to drive social change.  <span><br/></span><span><br/></span>Featuring the talents of:<span><br/></span><span><br/></span>Aaron Schwebel, violin, Artistic Director of Echo Chamber<span><br/></span>Andrea Ludwig, mezzo-soprano<span><br/></span>Dakota Scott-Digout, piano <span><br/></span>Jeanie Chung, piano<span><br/></span>Anna Finkel, dancer<span><br/></span>Marcel d’Entremont, tenor <span><br/></span>Zachary Cardwell, dancer<span><br/></span><span><br/></span><span><br/></span><span class=\"ItalicText\">Premium seating is $50, Standard seating is $40, and Economy seating is $30. Youth tickets (Age 20 and under) are $10. Prices are inclusive of taxes and fees. Seating is assigned.</span>
""";
  schema:startDate "2026-03-27T19:30:00"^^xsd:dateTime;
