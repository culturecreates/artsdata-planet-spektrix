<http://www.spektrix.com/darkehallsociety/event/32201AJKCHKSVHJRMVGRPSJQJNPNNBBBQ>
  a schema:Event;
  schema:name "Amici Singers – Mixed Tape";
  schema:description """
	Please join the <span class=\"BoldText\">Amici Singers</span> for a rockin’ time on May 2nd at 7 pm!  This community choir and its awesome band present a unique experience of rock and pop music with a choir!  It is sure to have you dancing in your seats with hits of the 70’s and 80’s.  Led by Artistic Director Corinne Groff and Apprentice Director Emma Cameron and featuring rock journalists Jim Tenford and Ross MacNab.  <span><br/></span><span><br/></span><span class=\"ItalicText\">Tickets are $25 for adults and $5 for youth ages 13-18, inclusive of fees and taxes.  Children 12 and under are free but a ticket must be booked for them. Seating is assigned. No refunds.</span>
""";
  schema:startDate "2026-05-02T14:30:00"^^xsd:dateTime;
