  a schema:Event;
  schema:name "Britten McGonigal Masters Recital";
  schema:description """
	Join us for a first year graduate student recital featuring soprano, <span class=\"BoldText\">Britten McGonigal</span>, accompanied by pianist <span class=\"BoldText\">Mark Ancheta</span>.  This recital features works by Mozart, Debussy, Bernstein, Bolcom, and more!<span><br/></span><span><br/></span><span class=\"ItalicText\">Admission is free.</span><span><br/></span>
