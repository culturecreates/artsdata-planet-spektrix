  a schema:Event;
  schema:name "Sweeney Todd: The Demon Barber of Fleet Street";
  schema:description """
	<span class=\"BoldText\">Regina Lyric Musical Theatre</span> is proud to present <span class=\"ItalicText\"><span class=\"BoldText\">Sweeney Todd: The Demon Barber of Fleet Street</span></span>, Stephen Sondheim’s acclaimed musical, known for its rich score and compelling storytelling. Set in Victorian London, the show explores themes of justice, resilience, ambition, and the consequences of obsession, offering audiences a dramatic and thought-provoking theatrical experience. <span><br/></span><span><br/></span>With the return of <span class=\"BoldText\">Rob Ursan</span> as director, it promises to be a fantastic show!<span><br/></span><span><br/></span><span class=\"ItalicText\"><span class=\"BoldText\">Parental guidance is suggested.</span></span><span><br/></span><span><br/></span><span class=\"ItalicText\">Tickets are $44.20 inclusive of fees and taxes.  Seating is assigned.</span>
""";
