<http://www.spektrix.com/darkehallsociety/event/29401ADJVTMPMVSKRPCKNPVMCRPLRQJRR>
  a schema:Event;
  schema:name "Collective Studios Movie Premiere – 4th Anniversary";
  schema:description """
	<span class=\"BoldText\">Collective Studios</span> is celebrating their 4th Anniversary!  This event will feature a pre-show celebration for their “champagne birthday” followed by their virtual showcase… the Movie Premiere!  The Movie Premiere features all the studio’s winter Music Videos, filmed and edited by RC Equina of Kwento Productions.  We are watching these videos on the big screen for the first time!  Enjoy professional dance videos filmed in a variety of styles, complete with rehearsal footage, hilarious behind the scenes extras, and special videos commemorating the studio’s 4 years!  The studio will also be raising money for their new non-profit, Community Dance Initiative, that is working to make dance more accessible by removing physical and financial barriers.  Everyone is welcome to attend… you don’t want to miss it!<span><br/></span><span><br/></span>The lobby opens at 6 pm, with on-stage festivities beginning at 7:15 pm.<span><br/></span><span><br/></span><span class=\"ItalicText\">Tickets are $40 (including fees and taxes). No refunds. Seating is not assigned.</span>
""";
  schema:startDate "2026-04-04T19:15:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/darkehallsociety/files/ce331831-cb95-49d2-9a97-ac76fa74c081.jpg>;
  schema:location <https://spektrix.com/darkehallsociety/location/201AGBHDRLQHNHPHKKMPKLGPMDRDTDMVL>;
  schema:url <https://purchase.darkehall.ca/EventAvailability?EventId=25401>;
  schema:offers _:084cbc9889fd4ea9a5a7470ba25c8cfd5290;
  schema:keywords "Dance";
  schema:duration "PT195M";
  schema:endDate "2026-04-04T22:30:00"^^xsd:dateTime .

_:084cbc9889fd4ea9a5a7470ba25c8cfd5290 a schema:AggregateOffer;
