  a schema:Event;
  schema:name "Love and Lieder";
  schema:description """
	Join us for an evening of familiar songs and duets celebrating the many sides of love.  This recital will feature Regina-born soprano, <span class=\"BoldText\">Allison Arends</span>, University of Regina faculty artist and mezzo-soprano, <span class=\"BoldText\">Tina Alexander-Luna</span>, and the fabulous <span class=\"BoldText\">Christopher Kayler</span> on piano.<span><br/></span><span><br/></span><span class=\"ItalicText\">Tickets are $20 for adults and $15 for seniors, inclusive of fees and taxes.  Students receive free admission but are asked to book a ticket.  Seating is not assigned.</span><span><br/></span>
""";
