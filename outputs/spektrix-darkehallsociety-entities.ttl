<http://www.spektrix.com/darkehallsociety/event/34001AGQQHTLTHTMBJQGPRQRMLLBGHNMV>
  a schema:Event;
  schema:name "Western Regional 3MT® Competition";
  schema:description """
	The <span class=\"BoldText\">University of Regina</span> is proud to host the <span class=\"BoldText\">Western Regional 3MT® Competition</span>, bringing together some of the most engaging and accomplished graduate student researchers from across Western Canada for one unforgettable evening. <span><br/></span><span><br/></span>Graduate students from the following universities will take a complex idea and turn it into a story that connects, challenges, and sparks curiosity, offering a unique window into the work graduate students are doing to better understand our world and contribute to their fields and communities.<span><br/></span>•	University of Alberta<span><br/></span>•	Athabasca University<span><br/></span>•	University of British Columbia<span><br/></span>•	University of British Columbia, Okanogan<span><br/></span>•	University of Calgary<span><br/></span>•	University of Lethbridge<span><br/></span>•	University of Manitoba<span><br/></span>•	University of Northern British Columbia<span><br/></span>•	University of Regina<span><br/></span>•	Royal Roads University<span><br/></span>•	University of Saskatchewan<span><br/></span>•	Simon Fraser University<span><br/></span>•	Thompson Rivers University<span><br/></span>•	Trinity Western University<span><br/></span>•	Vancouver Island University<span><br/></span>•	University of Victoria<span><br/></span>•	University of Winnipeg<span><br/></span><span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">Admission is free but registration is encouraged.  Please click on the button below to register to attend.</span></span><span><br/></span><span><br/></span>For more information about the 3MT Competition, visit: <a target=\"_blank\" href=\"https://www.uregina.ca/graduate-studies-research/urgradexperience/western3mt.html\">their website.</a><span><br/></span>
""";
