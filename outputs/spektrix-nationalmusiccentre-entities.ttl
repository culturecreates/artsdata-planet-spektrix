<http://www.spektrix.com/nationalmusiccentre/event/174401AQSTQHDKHJJHHNTVDNCCLJGQGJG>
  a schema:Event;
  schema:name "Echoes in Motion";
  schema:description """
	From the elegance of the Baroque court to the fire of the modern concert hall, dance forms take centre stage in this journey across centuries. Beginning with deconstructed versions of grand historical works leading to energetic modern pieces, each reimagines—with shifting combinations of violin, harpsichord, and piano—what it means to dance with both grace and fire. <span><br/></span><span><br/></span><a target=\"_blank\" href=\"https://www.google.com/maps/place/Studio+Bell,+home+of+the+National+Music+Centre/@51.0445506,-114.054786,17z/data=!3m1!4b1!4m5!3m4!1s0x53717aaa864fd43b:0x7609799479e4d20e!8m2!3d51.0445591!4d-114.0529828\">Studio Bell, 850 4 Street SE Calgary</a><span><br/></span><span><br/></span>Doors: 6:00 pm. Show: 7:00 pm.<span><br/></span><span><br/></span>Adult: $66 <span><br/></span>Senior (65+): $54 <span><br/></span>Student A440 Club (18-39): $25 <span><br/></span>Youth (7-17):$10<span><br/></span><span><br/></span>+ GST<span><br/></span> <span><br/></span>NMC Members get 15% off tickets. Sign in with the email address associated with your membership to have your tickets auto-discount.
""";
  schema:startDate "2026-09-12T19:00:00"^^xsd:dateTime;
