<http://www.spektrix.com/nationalmusiccentre/event/138401ACCQTGVLRVNGJGCPHHNHMNKHCCC>
  a schema:Event;
  schema:name "Echoes Across The Border: Laurel Canyon and the Northern Connection";
  schema:description """
	Echoes Across the Border brings together industry leaders to discuss how cross-border influences have shaped generations of artists such as Joni Mitchell and Neil Young, with a special focus on the '60s and '70s Laurel Canyon era.<span><br/></span><span><br/></span><a target=\"_blank\" href=\"https://www.google.com/maps/place/Studio+Bell,+home+of+the+National+Music+Centre/@51.0445506,-114.054786,17z/data=!3m1!4b1!4m5!3m4!1s0x53717aaa864fd43b:0x7609799479e4d20e!8m2!3d51.0445591!4d-114.0529828\">Studio Bell, 850 4 Street SE Calgary</a><span><br/></span><span><br/></span>8:00 am to 3:30 pm<span><br/></span><span><br/></span>Free Registration
""";
  schema:startDate "2025-10-04T08:00:00"^^xsd:dateTime;
