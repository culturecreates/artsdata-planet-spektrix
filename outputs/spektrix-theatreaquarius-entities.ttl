<http://www.spektrix.com/theatreaquarius/event/28601APDRTPPTPHLHSRDRCLCHBTNJRVPM>
  a schema:Event;
  schema:name "2025 Fall Acting: Once Upon a Stage (grades 2-3)";
  schema:description """
	<h1>ONCE UPON A STAGE (Grade 2 to 3)</h1><h2>Finding the Missing Piece!</h2><span><br/></span>Inspired by Shel Silverstein’s The Missing Piece, this playful theatre class invites young actors to explore big ideas like adventures, belonging and self-discovery! Students will explore their curiosity and build their confidence through collaborative skills. The classes end with an in class sharing to celebrate their journey!<span><br/></span><span><br/></span>Dates: Saturday, September 6 to Saturday, November 15<span><br/></span><span><br/></span>Times: 9:30 am – 11:00 am<span><br/></span><span><br/></span>Location: The Gasworks 141 Park Street North, Hamilton, second floor studio<span><br/></span><span><br/></span>No classes: Saturday, October 11 (Thanksgiving Weekend) <span><br/></span><span><br/></span>Cost: $297.00 <span><br/></span>
""";
  schema:startDate "2025-09-06T09:30:00"^^xsd:dateTime;
