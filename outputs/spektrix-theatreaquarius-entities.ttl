<http://www.spektrix.com/theatreaquarius/event/29001ALLPBTHVNSHLVJMKCMRSHGJJGQBT>
  a schema:Event;
  schema:name "2025 Fall Acting: Theatre Lab";
  schema:description """
	<h1>THEATRE LAB (Grade 7 & 8)</h1><h2>Mystery and Motive!</h2><span><br/></span>Inspired by Ellen Raskin’s The Westing Game, this mystery-themed class invites students to dive into character and discover clues as they bring this unforgettable novel to life. The session concludes with an in-class performance full of twists, secrets and surprises!<span><br/></span><span><br/></span>Dates: Saturday, September 6 – Saturday, November 15<span><br/></span><span><br/></span>Times: 1:30 pm – 3:30 pm<span><br/></span><span><br/></span>Location: The Gas Works, 141 Park Street North, Hamilton, second floor studio<span><br/></span><span><br/></span>No classes: Saturday, October 11 (Thanksgiving Weekend) <span><br/></span><span><br/></span>Cost: $297.00 <span><br/></span>
""";
