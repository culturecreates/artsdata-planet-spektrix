<http://www.spektrix.com/theatreaquarius/event/29401ADJVTMPMVSKRPCKNPVMCRPLRQJRR>
  a schema:Event;
  schema:name "2025 Fall Acting:  No Experience Necessary";
  schema:description """
	<h1>NO EXPERIENCE NECESSARY (Ages 18 and up)</h1><h2>Murder on the Orient Express</h2><span><br/></span>Dive into the world of suspense, secrets, and sharp dialogue. In this 10-week adult acting class, participants will explore scenes from Agatha Christie's Murder on the Orient Express, focusing on character work, ensemble dynamics, and building tension on stage.<span><br/></span>Perfect for both experienced performers and enthusiastic newcomers, this class is ideal for anyone and culminates in an informal showcase of selected scenes for friends and family.<span><br/></span><span><br/></span>Dates: Wednesday, September 10 – Wednesday November 19<span><br/></span><span><br/></span>Location: 190 King William Street –Studio Theatre<span><br/></span>East Studio Entrance<span><br/></span><span><br/></span>No classes: Wednesday, October <span><br/></span><span><br/></span>Cost: $297.00 plus HST<span><br/></span>
""";
  schema:startDate "2025-09-10T19:00:00"^^xsd:dateTime;
