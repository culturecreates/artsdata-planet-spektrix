<http://www.spektrix.com/theatreaquarius/event/28201ANLRQMDQPKBCRBQJSVDBPMCHQKNS>
  a schema:Event;
  schema:name "2025 Fall Musical Theatre: Showstoppers (grades 4-8)";
  schema:description """
	<h1>SHOWSTOPPERS (Grade 4 to 8)</h1><h2>Welcome to the Rock</h2>10 Weeks<span><br/></span><span><br/></span>Step into the heart of Newfoundland in this high-energy musical theatre class inspired by the hit Broadway show Come From Away! In Welcome to the Rock, students in Grades 4 to 8 will build their skills in acting, singing, and movement while exploring themes of kindness, resilience, and community.<span><br/></span><span><br/></span>The program culminates in a studio showcase performance for friends and family, where students will proudly present songs from the production in a celebration of storytelling, heart, and the power of coming together.<span><br/></span><span><br/></span>Location: Theatre Aquarius 190 King Williams Street, Studio Theatre<span><br/></span>East Studio Entrance<span><br/></span><span><br/></span><span><br/></span><span><br/></span>Cost: $300.00<span><br/></span>
""";
