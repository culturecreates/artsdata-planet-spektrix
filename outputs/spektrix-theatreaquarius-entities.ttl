<http://www.spektrix.com/theatreaquarius/event/29801AKHGBCBQNDCCBHCDGNPLGJBDMJSD>
  a schema:Event;
  schema:name "2025 Fall: Audition Intensive Workshop (grade 12)";
  schema:description """
	<h1>THEATRE SCHOOL AUDITION INTENSIVE (Grade 12)</h1><span><br/></span><span><br/></span>This three-hour workshop is designed for Grade 12 students preparing to audition for post-secondary theatre programs. Led by an experienced industry professional, participants will receive personalized coaching on their monologues and audition pieces in a supportive, focused environment. Whether you're polishing your material or looking for fresh insight, this intensive offers practical tools, feedback, and encouragement to help you feel confident and prepared for your upcoming auditions. <span><br/></span><span><br/></span>November 24 from 6:00 pm to 9:00 pm<span><br/></span><span><br/></span>Location: 190 King William Street, Studio Theatre<span><br/></span>East Studio Entrance<span><br/></span><span><br/></span>Cost: $50.00 plus HST<span><br/></span><span><br/></span>Maximum 10 students<span><br/></span>
""";
