  a schema:Event;
  schema:name "Showstoppers: Theatre Grades 4-8";
  schema:description """
	<h1>Showstoppers</h1><span><br/></span><h2>Musical Theatre Grade 4 to 8</h2><h2>Matilda</h2><span><br/></span>Unleash your inner genius in this fun filled Matilda the Musical class! Students will explore the story of Matilda, her incredible powers, and unforgettable characters through singing, dancing, and acting. With the help of catchy songs and energetic choreography, they’ll build their performance skills while having a blast. The class culminates in a vibrant final performance, where students will showcase their hard work and talent for family and friends. Get ready to be amazed!<span><br/></span>
""";
