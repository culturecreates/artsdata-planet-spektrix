<http://www.spektrix.com/sidwilliams/event/187201ATQTBPJHSKGGTCNKDVLSTDMSVGK> a schema:Event;
  schema:name "Come From Away";
  schema:description """
	<h2>Come From Away </h2><span><br/></span>A True Story of Kindness in the Wake of Crisis<span><br/></span><span><br/></span><span class=\"BoldText\">When the world stopped, their stories took flight.</span> <span><br/></span><span><br/></span>On September 11, 2001, thirty-eight planes carrying nearly 7000 passengers were unexpectedly grounded in the small town of Gander, Newfoundland. <span><br/></span><span><br/></span><span class=\"BoldText\">What happened next became legend.</span><span><br/></span><span><br/></span>A community of ordinary people opened their hearts and homes to strangers from across the globe, turning fear into friendship and isolation into unity. <span><br/></span><span><br/></span>This critically acclaimed musical, written by Canadians Irene Sankoff and David Hein, has won both awards and the adoration of audiences all over the world and it is now coming to the Sid Williams Theatre. <span><br/></span><span><br/></span>Filled with heart and humour and a soaring Celtic-inspired score, <span class=\"ItalicText\">Come From Away</span> reminds us of what humanity can do when we come together. Uplifting, fast-paced, and irresistibly moving, it’s the feel-good hit that will leave you cheering for the best in all of us, and proud to call Canada home. <span><br/></span><span><br/></span><span class=\"BoldText\">Book, Music and Lyrics</span> by IRENE SANKOFF and DAVID HEIN <span><br/></span><span class=\"BoldText\">Original Broadway Production</span> Junkyard Dog Productions <span><br/></span><span class=\"BoldText\">Orchestrations</span> by August Eriksmoen <span><br/></span><span class=\"BoldText\">Arrangements</span> by Ian Eisendrath <span><br/></span><span><br/></span><span class=\"BoldText\">CYMC Director</span> Lori Mazey  <span><br/></span><span class=\"BoldText\">CYMC Music Director</span> Carol Anne Parkinson and Dustin Lucas <span><br/></span><span class=\"BoldText\">CYMC Choreographer</span> Paul Gerritsen <span><br/></span><span><br/></span><span class=\"ItalicText\"><span class=\"BoldText\">COME FROM AWAY</span></span> is presented by special arrangement with Music Theatre International (MTI). All authorized performance materials are also supplied by MTI. <span><br/></span><span><br/></span>https://www.mtishows.com/
""";
  schema:startDate "2026-07-14T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/sidwilliams/files/9f9037fb-aff3-4dba-bed0-8ed951df2db9.jpg>;
  schema:location <https://spektrix.com/sidwilliams/location/201AGBHDRLQHNHPHKKMPKLGPMDRDTDMVL>;
  schema:organizer <https://spektrix.com/sidwilliams/organization/comox-valley-youth-music-centre>;
  schema:url <https://www.sidwilliamstheatre.com/events/come-from-away/>;
  schema:offers _:c92eb91bdcdc4d86a3b73bc5ae6539c21371;
  schema:keywords "Theatre";
  schema:duration "PT90M";
  schema:endDate "2026-07-14T21:00:00"^^xsd:dateTime .

