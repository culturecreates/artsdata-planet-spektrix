<http://www.spektrix.com/sidwilliams/event/191601AKVPNCQGSLVLSDMGMSDQTMKNKJG> a schema:Event;
  schema:name "Brent Butt";
  schema:description """
	<span class=\"BoldText\">Brent Butt</span> has long been considered one of the funniest people in Canada, with a career in stand-up comedy that stretches into five decades.  <span><br/></span><span><br/></span>He has had numerous appearances at major festivals in multiple countries and was voted  <span class=\"BoldText\">Best Male Stand-Up in Canada</span> by his peers in the profession. He also created and starred in two successful sitcoms – <span class=\"BoldText\">CORNER GAS</span> (“Funniest Show on TV” as voted by TV Guide Readers, currently in 60 countries) and <span class=\"BoldText\">HICCUPS</span> (multiple Leo and Writers Guild Awards.)<span><br/></span> <span><br/></span>New book \"Huge\" out now. <span><br/></span><span><br/></span>Don’t miss Brent Butt at the Sid Williams Theatre in Courtenay, coming September 2026! 
""";
  schema:startDate "2026-09-22T19:30:00"^^xsd:dateTime;
