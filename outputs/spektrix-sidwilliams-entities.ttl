<http://www.spektrix.com/sidwilliams/event/162601AHTGPMTHKCQBHNMGVNSJCDRJPQB> a schema:Event;
  schema:name "Shari Ulrich & The Unfaithful Servants";
  schema:description """
	<span class=\"BoldText\">Shari Ulrich</span>, is a Juno Award-winning singer-songwriter and cherished voice in Canadian folk for over four decades. Known for her beloved work as a solo artist and with groups such as The Hometown Band, Pied Pumkin, and collaborative projects with Barney Bentall, Bill Henderson, and Roy Forbes, Shari Ulrich brings her signature warmth, wit, and deep musicality to the stage. Renowned for her soaring vocals and skill on violin and piano, Ulrich’s songs are both deeply personal and universally resonant. <span><br/></span><span><br/></span>Sharing the bill are <span class=\"BoldText\">The Unfaithful Servants</span>, a dynamic folk-bluegrass-Americana quartet praised for their rich harmonies, masterful musicianship, and compelling songwriting. Based on Vancouver Island, the group has been making waves with their heartfelt live performances and critically acclaimed recordings. Widely regarded as one of Canada’s standout acoustic ensembles, The Unfaithful Servants continue to earn a devoted following across the roots music scene. The Unfaithful Servants are on tour celebrating the release of their new album 'Fallen Angel'. <span><br/></span><span><br/></span>For this special evening, each artist will perform their own set plus there will be various  collaborations throughout the night, bringing these two musical worlds together in an exciting display of Canada's finest, all on one stage. <span><br/></span><span><br/></span>Don't miss this unique opportunity to experience <span class=\"BoldText\">two powerful acts in one unforgettable night.</span><span><br/></span>
""";
  schema:startDate "2026-03-07T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/sidwilliams/files/f1f5138c-66cf-4867-8ad9-d842279b065c.jpg>;
  schema:location <https://spektrix.com/sidwilliams/location/201AGBHDRLQHNHPHKKMPKLGPMDRDTDMVL>;
  schema:organizer <https://spektrix.com/sidwilliams/organization/cascadia-concerts>;
  schema:url <https://www.sidwilliamstheatre.com/events/shari-ulrich-the-unfaithful-servants/>;
