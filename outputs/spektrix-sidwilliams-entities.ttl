<http://www.spektrix.com/sidwilliams/event/165401AQQQBJBJDSNCTSGHTTRSPKRGVJS> a schema:Event;
  schema:name "Opera, Are You Kidding Me?";
  schema:description """
	Opera's greatest hits presented in a fun, down-to-earth showcase guaranteed to leave you filled with laughter and a new appreciation for opera. An internationally renowned roster will amaze and delight.<span><br/></span><span><br/></span>Featuring the amazing Dutch Soprano<span><br/></span>Anne Grimm<span><br/></span><span><br/></span>The Notorious Canadian Tenor<span><br/></span>Benjamin Butterfield<span><br/></span><span><br/></span>The Infamous British Baritone<span><br/></span>Alexander Dobson<span><br/></span><span><br/></span>And South Korea’s virtuosic violinist<span><br/></span>Jimin Shin Dobson<span><br/></span><span><br/></span><span class=\"ItalicText\">Opera, Are You Kidding Me?</span> features beloved arias and duets from the world's most popular operas with a few hidden gems thrown in for kicks. Singers will be joined by solo violin and piano accompaniment.<span><br/></span>
""";
