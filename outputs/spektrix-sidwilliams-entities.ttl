<http://www.spektrix.com/sidwilliams/event/177201AQKMQQMSCLQHCBNNVKKTNKKLDHL> a schema:Event;
  schema:name "Courtenay Comedy Classic";
  schema:description """
	After filling theatres from coast to coast, Jokers Canada is thrilled to (finally!) be making its Courtenay debut with a lineup of our country’s best comedians.<span><br/></span><span><br/></span>Enjoy a night of hilarious Pro Stand-up comedy.<span><br/></span><span><br/></span><span class=\"UnderlineText\">Scheduled Performers</span> <span><br/></span><span><br/></span><span class=\"BoldText\">Damonde Tschritter</span> <span class=\"ItalicText\">(HBO / Conan + Winner Of International Comedy Festival In Seattle)</span><span><br/></span><span><br/></span><span class=\"BoldText\">Ryan Williams</span> <span class=\"ItalicText\">(Just For Laughs + CBC's The Debaters)</span> <span><br/></span><span><br/></span><span class=\"BoldText\">Syd Bosel</span> <span class=\"ItalicText\">(Canada’s Got Talent + Winnipeg Comedy Festival)</span><span><br/></span><span><br/></span><span class=\"BoldText\">Adam Christie</span> <span class=\"ItalicText\">(Winner Of Sirius XM Top Comic + Former lead writer for This Hour Has 22 Minutes)</span> <span><br/></span><span><br/></span><span class=\"BoldText\">Aaron Arya</span> <span class=\"ItalicText\">(National Touring + Departure Festival Toronto)</span><span><br/></span><span><br/></span><span><br/></span><span class=\"ItalicText\">*Lineup subject to change due to unforeseen circumstance</span><span><br/></span><span><br/></span><span><br/></span>Event & lineup details —> @jokerscanada<span><br/></span><span><br/></span>Questions? Info@jokerscanada.ca
""";
