<http://www.spektrix.com/sidwilliams/event/163003AVHSPPQSRSTBQHBVQGJJVMRMNJB> a schema:Event;
  schema:name "Ebony Roots";
  schema:description """
	<span class=\"BoldText\">A Concert Celebrating Black/African Descent Music</span><span><br/></span><span><br/></span>This powerful and intimate music experience journeys through prison work-songs, passionate spirituals, iconic songs from the stage, to the emergence of Black Soul, R&B, Blues and Motown, including a tribute to some of Vancouver's legacy artists.<span><br/></span><span><br/></span>The artistic team, as led by Brandon Thornhill and Olaf de Shield, designed this musical journey through Black music which loosely narrates the evolving emancipation of the Black community, through music, from the North American perspective.<span><br/></span><span><br/></span>This project was produced by Brandon Thornhill with support from Vancouver's own award-winning company, Sound the Alarm: Music/Theatre.
""";
  schema:startDate "2026-02-13T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/sidwilliams/files/642f2649-0dc6-4608-8f54-755daef74b49.jpg>;
