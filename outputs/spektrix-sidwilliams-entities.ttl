  schema:organizer <https://spektrix.com/sidwilliams/organization/sid-williams-theatre-society>;
  schema:url <https://www.sidwilliamstheatre.com/events/red-fever/>;
  schema:offers _:084cbc9889fd4ea9a5a7470ba25c8cfd963;
  schema:keywords "Film - Documentary";
  schema:duration "PT60M";
  schema:endDate "2026-03-05T20:30:00"^^xsd:dateTime .

