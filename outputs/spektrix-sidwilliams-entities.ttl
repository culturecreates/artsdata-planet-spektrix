  schema:url <https://www.sidwilliamstheatre.com/events/getting-under-the-myth-of-canadian-history-with-michelle-good/>;
  schema:offers _:084cbc9889fd4ea9a5a7470ba25c8cfd948;
  schema:keywords "Speaker";
  schema:duration "PT60M";
  schema:endDate "2026-04-09T20:00:00"^^xsd:dateTime .

