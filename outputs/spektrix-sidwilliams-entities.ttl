<http://www.spektrix.com/sidwilliams/event/199201AQKKTKLQJCJNCHHMGTMPLQNPMSQ> a schema:Event;
  schema:name "Winter Harp";
  schema:description """
	Celebrate Christmas with Winter Harp - one of our most popular holiday shows. Glorious music and song combine with festive stories to warm your heart and wrap you in the Christmas spirit.  <span><br/></span> <span><br/></span>Winter Harp is a Christmas masterpiece. Velvet gowns, golden instruments, candles, and backdrops of cathedrals and snow combine to transport you to another time and place. Classical and Celtic harps, flutes and rare medieval instruments, percussion, poetry and singing envelop you in the silken cloak of Christmas. Familiar carols, along with songs ancient and rare, celebrate the season and set your heart singing. <span><br/></span> <span><br/></span>Don't miss this journey of pure magic! Winter Harp - Christmas begins here. <span><br/></span> <span><br/></span><span class=\"ItalicText\">\"Winter Harp's annual Christmas concerts are a treat\"</span> - Jurgen Gothe, CBC Radio 
""";
  schema:startDate "2026-12-14T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/sidwilliams/files/ea457751-bd2e-483f-85cc-a9ea99326d76.jpg>;
