<http://www.spektrix.com/theisabel/event/54201ATDGHQSBGRJPLVKLMRQMLSGRSDLV> a schema:Event;
  schema:name "Élisabeth Pion";
  schema:description """
	Pianist Élisabeth Pion, Gold Laureate of the 2025 Honens International Piano Competition, is celebrated for her expressive and imaginative playing. Her recital program spans Grażyna Bacewicz’s Sonata No. 2 in E minor, Chopin’s Etudes, Op. 25, Brahms’ Intermezzi Op. 117, and Schubert/Liszt transcriptions including <span class=\"ItalicText\">Der Müller und der Bach</span>, <span class=\"ItalicText\">Gretchen am Spinnrade</span>, <span class=\"ItalicText\">Auf dem Wasser zu Singen</span>, and <span class=\"ItalicText\">Erlkönig</span>, showcasing both masterworks and rarely heard repertoire. With her artistry and versatility, Élisabeth Pion is a rising star in the national and international piano world.
""";
  schema:startDate "2027-05-09T14:30:00"^^xsd:dateTime;
  schema:location <https://spektrix.com/theisabel/location/401ANPJQJQPQMRSBDNMVNLSPGTRBVQVRH>;
