<http://www.spektrix.com/theisabel/event/37401ACMVCJPTCNKQSKTHCVRCQVKKGRPH> a schema:Event;
  schema:name "Abby Stewart";
  schema:description """
	Abby Stewart is a Kingston native, country singer, and songwriter. She's opened for Hunter Hayes on his Tattoo Your Name Canadian Tour dates along with Dan + Shay, and has had the privilege of singing duets with Dean Brody, Dallas Smith, Aaron Pritchett and the Hunter Brothers. Stewart has opened for many Canadian talents, most recently Brett Kissel in Toronto at the CNE and in Ottawa on his Ice, Snow and 30 Below Tour, as well as for Tebey, Michelle Wright, Emerson Drive, and Tim Hicks. She has had the great pleasure of performing at some of Canada’s biggest music festivals, including Boots and Hearts Music Festival, Havelock Country Jamboree, Trackside Music Festival and many others.<span><br/></span><span><br/></span><span><br/></span>Please Note: Only tickets purchased directly from the Isabel Box Office or the Isabel Website will be valid for performances presented by the Isabel Bader Centre for the Performing Arts.
""";
  schema:startDate "2026-01-23T20:00:00"^^xsd:dateTime;
