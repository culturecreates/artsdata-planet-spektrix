<http://www.spektrix.com/theporttheatre/event/15401AGBHLPJQSLGSGPTPRKHBGTDKGKJN> a
    schema:Event;
  schema:name "Victoria Symphony ";
  schema:description """
	<h1>THE PLANETS - SYMPHONY IN SPACE</h1><span><br/></span>CONDUCTOR: Sean O'Loughlin<span><br/></span><span><br/></span>Prepare to blast off as our special guests, the Victoria Symphony brings you music from out of this world. Expect to visit a few of The Planets as depicted by Gustav Holst, Mozart, and Strauss. Enjoy favourite themes by John Williams from Star Wars, recall the drama of Apollo 13, relive Star Trek through the years, and more! From concert classics to inspired film scores, your imagination will take flight.<span><br/></span><span><br/></span>PROGRAMME:<span><br/></span><span><br/></span>Also Sprach Zarathustra, Introduction  Richard Strauss<span><br/></span>Mars from The Planets Holst<span><br/></span>Symphony No. 41 \"Jupiter” (IV. Molto Allegro)    Mozart<span><br/></span>Blue Danube Waltz excerpt J. Strauss<span><br/></span>Close Encounters John Williams<span><br/></span> <span><br/></span>Intermission<span><br/></span> <span><br/></span>Star Trek Through the Years      arr. Calvin Custer<span><br/></span>Star Wars: The Force Awakens John Williams, arr. Sean O’Loughlin<span><br/></span>Star Wars Suite II. Princess Leia’s Theme John Williams<span><br/></span>Star Wars Suite III. The Imperial March John Williams<span><br/></span>Music from Apollo 13 James Horner, arr. John Moss<span><br/></span>“Jupiter” from The Planets Holst<span><br/></span>
""";
  schema:startDate "2026-01-23T19:30:00"^^xsd:dateTime;
