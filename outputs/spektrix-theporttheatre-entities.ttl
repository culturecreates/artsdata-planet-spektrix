<http://www.spektrix.com/theporttheatre/event/80001ADKNNLRVJJNLRCNBCHMDBTSMBPBV> a
    schema:Event;
  schema:name "DanceABLE";
  schema:description """
	Crimson Coast Dance Society presents the 28th annual InFrinGinG Dance Festival<span><br/></span>July 8-12, 2026 <span><br/></span>INdoor and OUT – Downtown and All Around!<span><br/></span> <span><br/></span>A matinee of epic proportions – a community of dancers to inspire joy, hope and endless possibilities.<span><br/></span><span><br/></span>Arising from our bi-monthly Mixed Abilities Dance Jam and soaring into our hearts, this production gives wings to what is possible when you love dance and believe in yourself and each other.<span><br/></span><span><br/></span>Participants in the Mixed Abilities Dance Jam spend 10 intensive rehearsals with their facilitators, Myriam Verzat, Laura Jesson Love, Tatiana Hassan, and Kyle Shepard (yes, that Kyle) to create a short work tall on power – the power to change people.  Diversity defines the best of us and this show highlights inclusivity and creativity.<span><br/></span> <span><br/></span>You don’t want to miss this– your heart will grow 10 sizes.<span><br/></span><span><br/></span>Please go to <a target=\"_blank\" href=\"https://crimsoncoastdance.com/\">CRIMSONCOASTDANCE.COM</a> to learn about all of the festival events.
""";
  schema:startDate "2026-07-08T12:00:00"^^xsd:dateTime;
