<http://www.spektrix.com/theporttheatre/event/56201AGSGSGJVVGPLSGRNJSLQQTTQHHRQ> a
    schema:Event;
  schema:name "BC Cadet Honour Band";
  schema:description """
	The BC Cadet Honour Band is back for another concert tour through British Columbia! <span><br/></span><span><br/></span>Featuring 50 of the top Royal Canadian Sea, Army, and Air Cadet musicians from across the province, these cadets spend 4 days in rehearsal before proceeding on a short tour. The concert features a variety of music from popular to marches and features a band of Pipes and Drums. Please join us for an amazing evening of music and celebrate our young musicians. <span><br/></span><span><br/></span><span class=\"BoldText\">Tickets are free but must be reserved.</span>
""";
