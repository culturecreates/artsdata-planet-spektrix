<http://www.spektrix.com/theporttheatre/event/83001AHRQMSRRDJKSVNJJNHBJRBGMRMDP> a
    schema:Event;
  schema:name "SIZZLE: From The Deep ";
  schema:description """
	Explore the rich, resonant world of the low strings! From sonorous, lyrical lines, to bold rhythmic energy, From the Deep invites the audience into an immersive and unique soundscape of 3 cellos and a bass, answering the all-important question – “How low can you play?”<span><br/></span><span><br/></span>MUSICIANS<span><br/></span>Cellos: Hannah Addario-Berry, Alexandra Lee, Amy Laing; Double Bass: Michael Vaughan<span><br/></span><span><br/></span>PROGRAMME*<span><br/></span><span><br/></span>TELEMANN: Concerto No. 3 (arr. for 4 cellos)<span><br/></span><span><br/></span>BARTOK: 8 Pieces for Cello Quartet (arr. Henry Brown)<span><br/></span>I.	Ballad <span><br/></span>II.	Winter Solstice Song <span><br/></span>III.	Jest v. Allegretto <span><br/></span><span><br/></span>ARVOLES YORAN: Ladino Folk Song (arr. Yuriy Leonovich) <span><br/></span><span><br/></span>MOO LEE HUA: Chinese Folks Song (arr. Joanne Martin) <span><br/></span><span><br/></span>CLARA SCHUMANN: Praeludium & Fuga (arr. Irene Tsao) <span><br/></span><span><br/></span>MEL BONIS: Meditation (arr. A. Lee)<span><br/></span><span><br/></span>BORODIN: Nocturne Theme (from String Quartet No. 2) (arr. Nick Halsey) <span><br/></span><span><br/></span>JOSÉ L. ELIZONDO: Danzas Latinamericanas <span><br/></span>i.	Otoño en Buenos Aires <span><br/></span>ii.	Atardecer Tapatío <span><br/></span><span><br/></span>Natasha Jaffe: Prelude Down the Bach (on JS Bach)<span><br/></span><span><br/></span>*programming subject to change<span><br/></span>
""";
  schema:startDate "2026-08-04T13:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/theporttheatre/files/1add7f7b-19db-4af6-8336-40593bc6c594.jpg>;
