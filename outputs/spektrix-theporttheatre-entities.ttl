<http://www.spektrix.com/theporttheatre/event/66401ABGHVCPGPCLVNGNMHHVHCCMPBDSP> a
    schema:Event;
  schema:name "Arabian Nights ";
  schema:description """
	PRE-CONCERT TALK 6:30PM   CONCERT 7:30PM  <span><br/></span>GUEST CONDUCTOR: Jonathan Girard<span><br/></span><span><br/></span>Featuring our new Concertmaster, Joan Blackman, this concert begins in a combustion of rhythm and light, taking the audience on an inspirational journey, including one of Rimsky-Korsakov’s most popular works, Scheherazade, inspired by the Arabic folktales One Thousand and One Nights.<span><br/></span><span><br/></span>Programme:<span><br/></span>LOUIE: Music for a Celebration<span><br/></span>BRAHMS: Variations on a Theme by Haydn<span><br/></span>RIMSKY-KORSAKOV: Scheherazade, Op. 35<span><br/></span><span><br/></span>Read more about the Vancouver Island Symphony, Guest Artists and the music at <a target=\"_blank\" href=\"http://www.vancouverislandsymphony.com\"> www.vancouverislandsymphony.com</a> <span class=\"ItalicText\">Driven by Passion. United in Sound</span><span><br/></span>Stay updated on <a target=\"_blank\" href=\"https://www.facebook.com/vanislesymphony\"> Facebook</a> and <a target=\"_blank\" href=\"https://www.instagram.com/vancouverislandsymphony/\"> Instagram</a>
""";
  schema:startDate "2026-10-17T19:30:00"^^xsd:dateTime;
