<http://www.spektrix.com/theporttheatre/event/65601ABJVQCQRNKJTHQGGNGBHPDGVBKKD> a
    schema:Event;
  schema:name "Arang Music Ensemble - Tickets Available at Door";
  schema:description """
	The music group <span class=\"BoldText\">Arang</span> was formed in 2025 in Vancouver by Iranian immigrant artists with the goal of promoting and introducing Persian-language music and Iranian classical traditions to broader audiences.<span><br/></span><span><br/></span>The group has presented several performances in Vancouver and continues to actively share Persian musical heritage with diverse communities.<span><br/></span><span><br/></span>Group Members:<span><br/></span>• Esmaeel Bahiraie – Santur, Setar, and Handpan player with over 30 years of performance experience and more than 20 years of teaching experience.<span><br/></span><span><br/></span>• Shahrokh Ghazneiyni – Kamancheh and Setar player with over 30 years of experience in performance and music education.<span><br/></span><span><br/></span>• Hamed Samad Beigi – Tar, Setar, and Daf player with over 30 years of performance experience and more than 20 years of teaching experience.<span><br/></span><span><br/></span>• Taha Golkar – Daf and Tombak player with over 30 years of performance experience and more than 20 years of teaching experience.<span><br/></span><span><br/></span><a target=\"_blank\" href=\"https://www.instagram.com/navaye.kereshmeh?utm_source=qr&amp;amp;igsh=ODF5dmt6Zm0waDJw\"> Esmaeel Bahiraie Instagram</a><span><br/></span><span><br/></span><a target=\"_blank\" href=\"https://www.instagram.com/shahrokhghazneiyni?utm_source=qr&amp;amp;igsh=MTVjd3NzZmFpNTFoa\"> Shahrokh Ghazneiyni Instagram</a> <span><br/></span><span><br/></span><a target=\"_blank\" href=\"https://www.instagram.com/hamed_samadbeigi?utm_source=qr&amp;amp;igsh=MTdsZm5oZ3g2a3FtNA\"> Hamed Samad Beigi Instagram</a><span><br/></span><span><br/></span><a target=\"_blank\" href=\"https://www.instagram.com/tahagolkar?utm_source=qr&amp;amp;igsh=dnNteXY3MDZvbGNi\"> Taha Golkar Instagram</a><span><br/></span><span><br/></span>
""";
