<http://www.spektrix.com/theporttheatre/event/71002ASCMCKCBKSBHNNMMJSTMKNRGTRVT> a
    schema:Event;
  schema:name "NANAIMO CONCERT BAND Fall Concert";
  schema:description """
	Nanaimo Concert Band returns to the Port Theatre, Nanaimo’s premier waterfront theatre, for its annual Fall Concert.<span><br/></span><span><br/></span>Nanaimo Concert Band will perform music from a variety of genres offering a musical program which all generations can enjoy together at an extremely affordable price.  Music has the power to express the full range of human emotions and can take the listener on a journey – whether the musical genre is classical, pop, show tunes, swing, jazz or a toe tapping march.<span><br/></span><span><br/></span>Nanaimo Concert Band believes that there is nothing better than the live music experience shared with an audience. Music is powerful and live music is food for the senses.<span><br/></span><span><br/></span>Won’t you join us?<span><br/></span><span><br/></span><a target=\"_blank\" href=\"http://nanaimoconcertband.com/events/\"> Nanaimo Concert Band Events</a>
""";
  schema:startDate "2026-11-01T14:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/theporttheatre/files/42c14346-3d71-4e1c-9db9-9af183632311.jpg>;
