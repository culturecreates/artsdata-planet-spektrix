<http://www.spektrix.com/theporttheatre/event/62601ATRDJLLGPPDCDCLHRDMCJVJGKDVB> a
    schema:Event;
  schema:name "Symphony Community Day (Ages 6+)";
  schema:description """
	<span class=\"BoldText\">Presented by the Vancouver Island Symphony</span><span><br/></span><span><br/></span><span class=\"UnderlineText\"> • Musical Instrument Zoo</span> ~ <span class=\"BoldText\">9:30AM to 10:30AM</span> in the Port Theatre Lobby<span><br/></span><span class=\"UnderlineText\"> • Open Rehearsal</span> ~ <span class=\"BoldText\">11:00 to 12:00PM</span> on the Port Theatre Main Stage<span><br/></span><span><br/></span>This FREE Symphony event invites children ages 6 and up to The Port Theatre for a day of musical exploration, experimentation and fun. Participants can meet a musician, try out an orchestral instrument (must be ages 6+), listen to a rehearsal and learn what it takes to put on a symphonic concert.<span><br/></span><span><br/></span><span class=\"BoldText\">This event is FREE but you must book a ticket to participate in the Open Rehearsal</span>
""";
