<http://www.spektrix.com/bardonthebeach/event/179602AKGQJQTJTPPBMNVDKQSKDMBKQMV> a
    schema:Event;
  schema:name "Bard Explored: Antigone";
  schema:description """
	<h1>BARD EXPLORED: ANTIGONE</h1><h2>Explore the Season’s plays through these lively, engaging talks with acclaimed scholars. Go beyond the story and learn about the ideas, influences, and inspirations. Bring your questions and leave with thoughtful insight and an even greater appreciation for all four of this Season’s plays.</h2><span class=\"BoldText\">Tickets for Bard Explored are $15 each or all four for $45</span><span><br/></span><span class=\"ItalicText\">All four of the Bard Explored sessions will be held in the BMO Mainstage Theatre.</span><span><br/></span><span><br/></span>All Bard Explored talks begin at <span class=\"BoldText\">11am</span>. Each talk will run approximately 60 minutes, including a Q&A.<span><br/></span><span><br/></span><span class=\"BoldText\">Please Note: The Festival site opens 30 minutes before Bard Explored talks.</span>
""";
  schema:startDate "2026-08-15T11:00:00"^^xsd:dateTime;
