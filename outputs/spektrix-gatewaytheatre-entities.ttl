<http://www.spektrix.com/gatewaytheatre/event/94801AQGDVBVLGRCLPPTDPPJTRRNKCQLR> a
    schema:Event;
  schema:name "Summer Musical Theatre Performance";
  schema:description """
	<span class=\"BoldText\">Musical Theatre Performance (2-Week Intensive)</span><span><br/></span>Ages 8–13<span><br/></span>July 20-31 (Monday-Friday) | 9:00am-4:00pm<span><br/></span><span><br/></span>The ultimate performance experience. This camp is perfect for students keen on experiencing process-focused training with added technical elements, including props and lighting. Students will work on an exciting collection of musical theatre pieces from shows such as Wicked, The Sound of Music, and more! A final public performance, including a technical and dress rehearsal day, will give students a taste of how the magic of theatre comes together. Students will also receive a Gateway Academy t-shirt to be worn for their final showcase (included in tuition).<span><br/></span><span><br/></span>Auditions are required for this camp.<span><br/></span><span><br/></span>Please note: All class withdrawals are subject to a 30% course withdrawal fee. View full <a target=\"_blank\" href=\"https://www.gatewaytheatre.com/gateway-academy-terms-conditions\">Refund/Cancellation Policy here</a>
""";
