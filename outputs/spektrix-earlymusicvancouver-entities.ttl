  schema:organizer <https://spektrix.com/earlymusicvancouver/organization/early-music-vancouver>;
  schema:url <https://www.earlymusic.bc.ca/events/songs-from-the-mayflower-with-menestrel/>;
  schema:offers _:78f1e3f00e524974ab72909aa5a3a4a93009;
  schema:duration "PT60M";
  schema:endDate "2027-04-30T20:30:00"^^xsd:dateTime .

