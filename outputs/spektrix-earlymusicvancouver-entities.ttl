<http://www.spektrix.com/earlymusicvancouver/event/8801ABJDKGQJJPHNLQGQLLLRMHJSKRCGT>
  a schema:Event;
  schema:name "Amour Courtois: Medieval Meets Jazz";
  schema:description """
	<h1>Amour Courtois: Medieval Meets Jazz</h1><span><br/></span><img src=\"https://system.spektrix.com/earlymusicvancouver/files/53993468-ebd4-4009-a090-5a5b5920f319.jpg\" /><span><br/></span><span><br/></span>Amour Courtois is a bold and evocative musical project led by French jazz pianist Baptiste Bailly, reimagining 14th-century French songs through the lens of contemporary improvisation. Inspired by the enduring emotional resonance of medieval melodies, Bailly collaborates with Matthew Baker on the baryton and Efren López on the hurdy-gurdy and ouds, crafting an anachronistic yet striking soundscape. Their repertoire – featuring works by Machaut, Binchois, and Lescurel – bridges centuries and highlights the timelessness of human expression.
""";
  schema:startDate "2026-03-13T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/earlymusicvancouver/files/53993468-ebd4-4009-a090-5a5b5920f319.jpg>;
  schema:location <https://spektrix.com/earlymusicvancouver/location/401ANPJQJQPQMRSBDNMVNLSPGTRBVQVRH>;
  schema:organizer <https://spektrix.com/earlymusicvancouver/organization/early-music-vancouver>;
  schema:url <https://www.earlymusic.bc.ca/events/amour-courtois-medieval-meets-jazz/>;
  schema:offers _:78f1e3f00e524974ab72909aa5a3a4a92987;
  schema:duration "PT60M";
  schema:endDate "2026-03-13T20:30:00"^^xsd:dateTime .

