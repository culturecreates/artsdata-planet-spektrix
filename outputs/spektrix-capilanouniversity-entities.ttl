<http://www.spektrix.com/capilanouniversity/event/16401ABVRRCMPGBBKHVKSLVNQTBRMLVRH>
  a schema:Event;
  schema:name " Disney's Dare to Dream Jr.";
  schema:description """
	<span class=\"ItalicText\"><span class=\"BoldText\">Disney’s Dare to Dream Jr.</span></span> is a 60-minute  junior musical theatre production, presented by Khial Art Foundation in collaboration with Cadenza Music & Art Academy. The show follows a group of young trainees on their first day at a fictional Walt Disney Imagineering Studio, where they explore their dreams and discover how imagination, collaboration, and courage can make anything possible.<span><br/></span><span><br/></span> <span><br/></span>Featuring songs from a wide range of beloved Disney films, this joyful musical revue brings together students of all levels, from new beginners to advanced young artists, each sharing their unique voice and creativity on stage.<span><br/></span><span><br/></span> <span><br/></span>A heartfelt celebration of growth, learning, and the magic of Disney storytelling, Dare to Dream JR. is brought to life by our dedicated students and young performers, with training and artistic development guided by Cadenza Music & Art Academy.<span><br/></span><span><br/></span><span><br/></span><h2><span class=\"BoldText\">COMMUNITY RENTAL EVENT</span></h2>
""";
  schema:startDate "2026-07-04T18:30:00"^^xsd:dateTime;
