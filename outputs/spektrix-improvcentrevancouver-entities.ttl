  a schema:Event;
  schema:name "House Teams LOL-A-PALOOZA";
  schema:description """
	<h2>Sunday, February 15th - SEASON OPENER!!</h2><span><br/></span>Vancouver’s standout improvisers from around the Lower Mainland are ready to show their stuff in back-to-back showcases!<span><br/></span><span><br/></span>We're proud to introduce you to our new house teams:<span><br/></span><span><br/></span><span class=\"BoldText\">RAT ANTICS<span><br/></span>DIRT CUPS<span><br/></span>DUNCAN</span><span><br/></span><span><br/></span>Tickets are only $10! And get this – happy hour prices are in effect all night long!<span><br/></span><span><br/></span>Run time: 90 minutes including intermission<span><br/></span><span><br/></span>PG – Some material may not be suitable for some audiences.<span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.<span><br/></span><span><br/></span>All physical vouchers must now be redeemed via phone or email. Please contact the box office for assistance.
""";
