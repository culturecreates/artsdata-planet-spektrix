<http://www.spektrix.com/improvcentrevancouver/event/45801APJPHDJMJCSGNSRNCNRNHDDTHVGL>
  a schema:Event;
  schema:name "Blockbuster: Musical Edition";
  schema:description """
	<h2>A special musical version of our hit format!</h2><span><br/></span>This show is a comedic exploration of our all-time favourite films and film genres and ENTIRELY made up on the spot! We need you to help us create the latest Blockbuster! Is it a Horror? Western? Sci-Fi with a Romantic twist? Come and find out! <span><br/></span><span><br/></span>For this special musical edition of Blockbuster, we'll have <span class=\"BoldText\">Peter Abando</span> performing with our cast as musical improviser!<span><br/></span><span><br/></span>The entire show will be one big musical - and unlike other Blockbuster you've ever seen!<span><br/></span><span><br/></span>Run time: 90 minutes including intermission<span><br/></span><span><br/></span>Rated: PG <span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.<span><br/></span><span><br/></span>All physical vouchers must now be redeemed via phone or email. Please contact the box office for assistance.<span><br/></span><span><br/></span><img src=\"https://system.spektrix.com/improvcentrevancouver/files/2417e867-c59b-4c69-abf5-e93632b186c4.jpg\" />
""";
  schema:startDate "2026-03-19T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/improvcentrevancouver/files/2417e867-c59b-4c69-abf5-e93632b186c4.jpg>;
  schema:location <https://spektrix.com/improvcentrevancouver/location/603AMBLCJQMLRJDMDQKBNHDKQPPDPCQLJ>;
  schema:organizer <https://spektrix.com/improvcentrevancouver/organization/the-improv-centre>;
  schema:url <https://theimprovcentre.ca/shows/>;
  schema:offers _:002da49907ad4172abad71415d1299175396;
