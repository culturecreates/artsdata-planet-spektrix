<http://www.spektrix.com/improvcentrevancouver/event/52802ASBGSGLPLGDBGVKVSJBMKCTTBTBG>
  a schema:Event;
  schema:name "Blockbuster";
  schema:description """
	<h2>Thursdays</h2><span><br/></span>This show is a comedic exploration of our all-time favourite films and film genres and ENTIRELY made up on the spot! We need you to help us create the latest Blockbuster! Is it a Horror? Western? Sci-Fi with a Romantic twist? Come and find out! <span><br/></span><span><br/></span>Run time: 90 minutes including intermission<span><br/></span><span><br/></span>Rating: 🌶️🌶️ – Content is cheeky, playful, some innuendo is possible. Think “Shrek” level content. Best for audiences age 8 and up. (PG)<span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.<span><br/></span><span><br/></span>All physical vouchers must now be redeemed via phone or email. Please contact the box office for assistance.<span><br/></span><span><br/></span><img src=\"https://system.spektrix.com/improvcentrevancouver/files/b318ff9d-d52a-4e85-b97d-3e4991c9f085.jpg\" />
""";
  schema:startDate "2026-06-11T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/improvcentrevancouver/files/b318ff9d-d52a-4e85-b97d-3e4991c9f085.jpg>;
