<http://www.spektrix.com/improvcentrevancouver/event/33401ASQTDQSSBKHDTGJNVLMTDQJCSHNC>
  a schema:Event;
  schema:name "Femmes Intro to Improv";
  schema:description """
	<h2>Free FEMME Workshop!</h2><span><br/></span><span class=\"BoldText\">Time:</span> 3:30pm – 5:30pm<span><br/></span><span class=\"BoldText\">Ages:</span> 19+<span><br/></span><span class=\"BoldText\">Level Required:</span> no improv experience is required!<span><br/></span><span class=\"BoldText\">Workshop Capacity:</span> 22 people<span><br/></span><span class=\"BoldText\">Cost:</span> FREE with registration<span><br/></span><span class=\"ItalicText\">Max 1 enrollment per email</span><span><br/></span><span><br/></span>This two-hour workshop is designed for femme-identifying participants who want to dip their toes into the world of improvisation—and celebrate International Women’s Day in style! Guided by our hilarious mainstage performers, you’ll explore the basics of “Yes, And!” in a warm, supportive space created to champion, uplift, and celebrate women. No experience needed—just bring your curiosity, your boldness, and your sense of fun!<span><br/></span><span><br/></span>All workshops and classes are 19+ only.<span><br/></span><span><br/></span>LOCK OUT POLICY: Doors will lock 15 minutes after the class begins. Late comers will not be permitted.
""";
  schema:startDate "2026-03-07T15:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/improvcentrevancouver/files/c753d794-9e17-4ce0-9b99-65bc0cc69aa8.jpg>;
  schema:location <https://spektrix.com/improvcentrevancouver/location/603AMBLCJQMLRJDMDQKBNHDKQPPDPCQLJ>;
  schema:organizer <https://spektrix.com/improvcentrevancouver/organization/the-improv-centre>;
  schema:url <https://theimprovcentre.ca/shows/>;
  schema:offers _:002da49907ad4172abad71415d1299175411;
  schema:duration "PT120M";
  schema:endDate "2026-03-07T17:30:00"^^xsd:dateTime .

