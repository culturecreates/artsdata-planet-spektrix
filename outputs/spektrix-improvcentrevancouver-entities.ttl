<http://www.spektrix.com/improvcentrevancouver/event/54401AVRJSJSMPPPTPSPMTMDGVPJBQJVD>
  a schema:Event;
  schema:name "Pride Race";
  schema:description """
	**Special Pride Improv Show**<span><br/></span><span><br/></span>Thursday, June 18th at 7:30pm<span><br/></span><span><br/></span>14A – May include suggestive language and/or scenes.<span><br/></span><span><br/></span>Get ready for a queer improv extravaganza! Inspired by RuPaul’s Drag Race, watch a cast of our fiercest and funniest as they compete in side-splitting improv challenges, all in to be crowned the next improv superstar. Whether you’re a die-hard Drag Race fan or just love spontaneous comedy, this show will leave you gooped AND gagged! Grab your best squirrel friends, throw on your sequins, and join us for a night of laughter, love, and unapologetic pride!<span><br/></span><span><br/></span><span class=\"BoldText\">Sliding Scale tickets start at just $15 and happy hour prices are in effect all night long!</span>
""";
