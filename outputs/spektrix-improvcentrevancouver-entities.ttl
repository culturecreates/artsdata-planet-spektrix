<http://www.spektrix.com/improvcentrevancouver/event/54401AVRJSJSMPPPTPSPMTMDGVPJBQJVD>
  a schema:Event;
  schema:name "Pride Race";
  schema:description """
	<span class=\"BoldText\">Special Pride Improv Show</span><span><br/></span><span><br/></span><h1>Get ready for a queer improv extravaganza!</h1><span><br/></span>Inspired by RuPaul’s Drag Race, watch a cast of our fiercest and funniest as they compete in side-splitting improv challenges, all in to be crowned the next improv superstar.<span><br/></span><span><br/></span>Whether you’re a die-hard Drag Race fan or just love spontaneous comedy, this show will leave you gooped AND gagged! Grab your best squirrel friends, throw on your sequins, and join us for a joy-filled night celebrating queer stories, love, and the LGBTQIA2S+ community!<span><br/></span><span><br/></span><span class=\"BoldText\">Sliding Scale tickets start at just $15 and happy hour prices are in effect all night long!</span><span><br/></span><span><br/></span>Run time: 90 minutes including intermission<span><br/></span><span><br/></span>🌶️🌶️🌶️ – Includes references to romantic relationships. May include light fighting or references to violence. There may be references to smoking or drug use. Best for teens and up. (14A)<span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.<span><br/></span><span><br/></span>All physical vouchers must now be redeemed via phone or email. Please contact the box office for assistance.<span><br/></span>
""";
  schema:startDate "2026-06-18T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/improvcentrevancouver/files/70aaffb6-99f2-4622-9185-0279939d794b.jpg>;
  schema:location <https://spektrix.com/improvcentrevancouver/location/603AMBLCJQMLRJDMDQKBNHDKQPPDPCQLJ>;
  schema:organizer <https://spektrix.com/improvcentrevancouver/organization/the-improv-centre>;
  schema:url <https://theimprovcentre.ca/shows/>;
  schema:offers _:1290a8eb9d794355b3e34223272b36866683;
  schema:duration "PT90M";
  schema:endDate "2026-06-18T21:00:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36866683 a schema:AggregateOffer;
