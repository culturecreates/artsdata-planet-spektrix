  a schema:Event;
  schema:name "House Teams Showcase";
  schema:description """
	<h2>Select Sundays at 7:30pm</h2><span><br/></span>Vancouver’s finest improv performers from around the Lower Mainland are ready to show their stuff in back-to-back showcases! It’s all teams, all talent, all hilarious at the new season of House Teams! <span><br/></span><span><br/></span>Tickets are only $10! And get this – happy hour prices are in effect all night long!<span><br/></span><span><br/></span>Run time: 90 minutes including intermission<span><br/></span><span><br/></span>PG – Some material may not be suitable for some audiences.<span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.<span><br/></span><span><br/></span>All physical vouchers must now be redeemed via phone or email. Please contact the box office for assistance.
""";
