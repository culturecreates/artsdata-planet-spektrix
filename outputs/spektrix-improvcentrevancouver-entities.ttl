<http://www.spektrix.com/improvcentrevancouver/event/30201AHVTMBBQKSVNPBBRMTKPDQPRMHJC>
  a schema:Event;
  schema:name "BIPOC Intro to Improv";
  schema:description """
	<h2>Free BIPOC Workshop!</h2><span><br/></span><span class=\"BoldText\">Time:</span> 3:30pm – 5:30pm<span><br/></span><span class=\"BoldText\">Ages:</span> 19+<span><br/></span><span class=\"BoldText\">Level Required:</span> no improv experience is required!<span><br/></span><span class=\"BoldText\">Workshop Capacity:</span> 22 people<span><br/></span><span class=\"BoldText\">Cost:</span>FREE with registration<span><br/></span><span class=\"ItalicText\">Max 1 enrollment per email</span><span><br/></span><span><br/></span>This free workshop for BIPOC identifying folks requires no experience to join! Looking to explore the world of improvisation? Join us for an engaging workshop for BIPOC participants, regardless of prior experience! Dive into the fundamentals of improv during this two-hour session designed specifically for beginners. Experience the joy of \"Yes, And!\" in a welcoming and supportive atmosphere. This workshop is for people who identify as Black, Indigenous, and/or People of Colour.<span><br/></span><span><br/></span>All workshops and classes are 19+ only.<span><br/></span><span><br/></span>LOCK OUT POLICY: Doors will lock 15 minutes after the class begins. Late comers will not be permitted.
""";
  schema:startDate "2026-02-07T15:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/improvcentrevancouver/files/7a055893-b0d8-45e5-9d32-aaf7a343274b.jpg>;
  schema:location <https://spektrix.com/improvcentrevancouver/location/603AMBLCJQMLRJDMDQKBNHDKQPPDPCQLJ>;
  schema:organizer <https://spektrix.com/improvcentrevancouver/organization/the-improv-centre>;
  schema:url <https://theimprovcentre.ca/shows/>;
  schema:offers _:f1e5d4ebb48e4f06bccb5a907ecb5f635407;
  schema:duration "PT120M";
  schema:endDate "2026-02-07T17:30:00"^^xsd:dateTime .

