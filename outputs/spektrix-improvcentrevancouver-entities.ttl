  schema:image <https://system.spektrix.com/improvcentrevancouver/files/e28dbde3-dcaf-4671-aa31-b3a762a47acc.jpg>;
  schema:location <https://spektrix.com/improvcentrevancouver/location/603AMBLCJQMLRJDMDQKBNHDKQPPDPCQLJ>;
