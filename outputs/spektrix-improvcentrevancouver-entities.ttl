<http://www.spektrix.com/improvcentrevancouver/event/60002ANTKMBNGTVNVGSPMJMBBCRVBDDJG>
  a schema:Event;
  schema:name "Canada Day Show";
  schema:description """
	<h1>OH, CANADA!</h1><span><br/></span>Inspired by experiences of locals and visitors alike, join us as we honour our favourite bits and pieces of Canada! Let’s celebrate our wonderful, scenic and friendly country together with an evening of laughter!<span><br/></span><span><br/></span>Run time: 90 minutes with a 15-minute intermission.<span><br/></span><span><br/></span>Rated: 🌶️🌶️ – Content is cheeky, playful, some innuendo is possible. Think “Shrek” level content. Best for audiences age 8 and up. (PG)<span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.<span><br/></span><span><br/></span>All physical vouchers must now be redeemed via phone or email. Please contact the box office for assistance.
""";
  schema:startDate "2026-07-01T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/improvcentrevancouver/files/9f85f813-8867-425e-9123-003837059826.jpg>;
  schema:location <https://spektrix.com/improvcentrevancouver/location/603AMBLCJQMLRJDMDQKBNHDKQPPDPCQLJ>;
  schema:organizer <https://spektrix.com/improvcentrevancouver/organization/the-improv-centre>;
  schema:url <https://theimprovcentre.ca/shows/>;
  schema:offers _:57e8ee661ad740a08e5ad0ea20bc4b346368;
  schema:duration "PT90M";
  schema:endDate "2026-07-01T21:00:00"^^xsd:dateTime .

