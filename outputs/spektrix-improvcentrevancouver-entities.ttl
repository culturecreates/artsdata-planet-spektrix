<http://www.spektrix.com/improvcentrevancouver/event/54601APCBTLTSHPQHKCBSVQKSMGPHQNNB>
  a schema:Event;
  schema:name "Father's Day Matinee";
  schema:description """
	<h1>Let Dad take a rest and leave the funny to us!</h1><span><br/></span>This Father’s Day, head down to The Improv Centre to celebrate fathers and father-figures-alike with an afternoon of laughter! Dedicated to backyard ball games, bad puns, and all things we love most about our father-ly role-models, this delightfully dad-inspired show will be fun for the whole family!<span><br/></span><span><br/></span>Run time: 90 minutes including intermission<span><br/></span><span><br/></span>Rated: 🌶️ – Suitable for all audiences. Children are encouraged to attend with a caregiver. (G)<span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.<span><br/></span><span><br/></span>This is a Special Show – Restricted vouchers and vouchers do not apply.
""";
  schema:startDate "2026-06-21T14:00:00"^^xsd:dateTime;
