<http://www.spektrix.com/improvcentrevancouver/event/58601AJJQLQQNQQDJSRQPDLNHTRMRQCHK>
  a schema:Event;
  schema:name "East Van School Showcase";
  schema:description """
	We invite you to a private performance showcasing the creativity of our East Van Schools educational improv program. As part of The Improv Centre’s commitment to community comedy education, these students have been honing their craft and are ready to share the stage.<span><br/></span><span><br/></span>Come cheer on the troupes from David Thompson, Gladstone, and Van Tech in an afternoon of spontaneous theater!<span><br/></span><span><br/></span><span class=\"BoldText\">Lounge & Patio Open:</span> 230pm (card only bar)<span><br/></span><span class=\"BoldText\">Theatre Open:</span> 3pm<span><br/></span><span class=\"BoldText\">Show Time:</span> 330pm-530pm (including a 15 intermission)<span><br/></span><span class=\"BoldText\">Reception:</span> 530pm-630pm<span><br/></span><span><br/></span>We’ll be hosting a post-show gathering in the lounge for all performers, friends, and family to celebrate a successful season.<span><br/></span><span><br/></span>Please Note: as The Improv Centre is a licensed facility, all minors (persons under the age of 19) must be accompanied by an adult.
""";
  schema:startDate "2026-05-30T15:30:00"^^xsd:dateTime;
  schema:location <https://spektrix.com/improvcentrevancouver/location/603AMBLCJQMLRJDMDQKBNHDKQPPDPCQLJ>;
  schema:organizer <https://spektrix.com/improvcentrevancouver/organization/the-improv-centre>;
  schema:url <https://theimprovcentre.ca/shows/>;
  schema:offers _:61bf61df540e4d49aa04255634b383c75402;
  schema:duration "PT120M";
  schema:endDate "2026-05-30T17:30:00"^^xsd:dateTime .

