<http://www.spektrix.com/improvcentrevancouver/event/22601ARRLHTVCDDNCQVPHHJKHRLVJHGRP>
  a schema:Event;
  schema:name "Community Jam";
  schema:description """
	<h2>FREE Monthly Improv Jam</h2><span><br/></span><span class=\"BoldText\">Time:</span> 3:30pm – 5:30pm<span><br/></span><span class=\"BoldText\">Ages:</span> 19+<span><br/></span><span class=\"BoldText\">Level Required:</span> no improv experience is required!<span><br/></span><span class=\"BoldText\">Cost:</span> FREE with registration<span><br/></span><span class=\"ItalicText\">Max 2 enrollments per email per jam</span><span><br/></span><span><br/></span>Have a craving for the stage? Come and improvise with professionally trained performers at our free community jam session where you can walk up, drop in, and learn from the pros. If you’ve been itching to get involved in the improv community, this is for you!<span><br/></span><span><br/></span>Register to sign up!<span><br/></span><span><br/></span>All workshops and classes are 19+ only.<span><br/></span>
""";
