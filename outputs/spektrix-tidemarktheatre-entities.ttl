  schema:location <https://spektrix.com/tidemarktheatre/location/421AQHGLBKGMNTQCBVLLKRBCJKMVDDMSG>;
  schema:url <https://tidemarktheatre.com/event/wine-brews-blues/>;
  schema:offers _:d25bd24b203747b0805b2b5a2fe2a7927187;
  schema:duration "PT90M";
  schema:endDate "2026-05-23T20:30:00"^^xsd:dateTime .

