  a schema:Event;
  schema:name "Campbell River Comedy Classic";
  schema:description """
	Need a laugh? After selling out theatres from coast-to-coast, Jokers Canada is thrilled to be making its Campbell River debut in March with an all-star lineup of our country’s BEST pro comedians.<span><br/></span><span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">Scheduled Performers: </span></span><span><br/></span><span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">Damonde Tschritter: (HBO / Conan + Winner Of International<span><br/></span>Comedy Festival In Seattle)</span></span><span><br/></span><span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">Ryan Williams: (Just For Laughs + CBC Debaters) </span></span><span><br/></span><span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">Syd Bosel: (Canada’s Got Talent + Winnipeg Comedy Festival)</span></span><span><br/></span> <span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">Adam Christie: (Winner Of Sirius XM Top Comic + Former lead<span><br/></span>writer for This Hour Has 22 Minutes) </span></span><span><br/></span><span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">Aaron Arya: (National Touring + Departure Festival Toronto)</span></span><span><br/></span><span><br/></span><span class=\"BoldText\"><span class=\"ItalicText\">*lineup subject to change due to unforeseen circumstance </span></span><span><br/></span><span><br/></span>Tickets: $49.00 Admission<span class=\"ItalicText\">(+applicable taxes & fees)</span> 
""";
