<http://www.spektrix.com/tidemarktheatre/event/57401ANHTKSRPPTMGTRKPHLCBHVSMPJSK>
  a schema:Event;
  schema:name "Brent Butt";
  schema:description """
	Brent Butt has long been considered one of the funniest people in Canada, with a career in stand-up comedy that stretches into five decades, including numerous appearances at major festivals in multiple countries and being voted <span class=\"BoldText\">Best Male Stand-Up in Canada</span> by his peers in the profession. He also created and starred in two successful sitcoms – <span class=\"BoldText\">CORNER GAS</span> <span class=\"ItalicText\">(“Funniest Show on TV” as voted by TV Guide Readers, currently in 60 countries)</span> and <span class=\"BoldText\">HICCUPS</span> <span class=\"ItalicText\">(multiple Leo and Writers Guild Awards)</span>.<span><br/></span><span><br/></span><a target=\"_blank\" href=\"https://brentbutt.com/\">https://brentbutt.com/</a><span><br/></span><span><br/></span>New book “Huge” out now<span><br/></span><span><br/></span>Tickets: $61.00 Admission, $55.25 Groups 10+ <span class=\"ItalicText\">(+applicable taxes & fees)</span>
""";
  schema:startDate "2026-09-24T19:30:00"^^xsd:dateTime;
