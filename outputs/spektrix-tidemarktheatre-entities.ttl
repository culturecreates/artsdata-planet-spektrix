<http://www.spektrix.com/tidemarktheatre/event/60601ATNTMJGPJLLKLVBRSMHPPDCNKPMC>
  a schema:Event;
  schema:name "Diabolo Dance Theatre of Taiwan";
  schema:description """
	<span class=\"BoldText\">A Spectacular Fusion of Culture and Innovation Connecting to the World</span><span><br/></span><span><br/></span>The Diabolo Dance Theatre Established in 1986, is a world-renowned performing arts group from Taiwan. They are famous for their unique “Diabolo Dance” performance, which elevates the traditional Chinese yo-yo (diabolo) into a mesmerizing contemporary stage art.<span><br/></span><span><br/></span>They seamlessly blend diabolos with modern dance, acrobatics, theatre, and stunning visual multimedia. Through dynamic choreography and emotional storytelling, their performances transcend language and cultural barriers, captivating audiences of all ages globally.<span><br/></span><span><br/></span>The troupe has toured over 30 countries and performed more than 3,000 shows. Their prestigious appearances include the New Lincoln Centre, World Expo, and major theatres worldwide, served as a shining cultural ambassador for Taiwan.<span><br/></span><span><br/></span>Tickets: $38.00 Adults, $33.00 Senior/Student, $23.00 Child 10-, $33.00 Groups 10+ <span class=\"ItalicText\">(+applicable taxes & fees)</span>
""";
  schema:startDate "2026-09-11T19:30:00"^^xsd:dateTime;
