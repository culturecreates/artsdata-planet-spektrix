<http://www.spektrix.com/factorytheatre/event/142214ACCDQVNNLQQPNKGPDVRHSSLCJJS> a
    schema:Event;
  schema:name "12 Litres 8800 Steps";
  schema:description """
	Created, directed and performed by Anita La Selva; Co-directed by Beatriz Pizano<span><br/></span><span><br/></span><span class=\"ItalicText\">12 Litres 8800 Steps</span> is an interdisciplinary theatrical odyssey that invites us into the world of people who have lost loved ones to addiction: one woman’s journey in coming to terms with the fragility of her own mental health while witnessing the demise of her partner through addiction. A Horse appears and magic realism collides with the everyday reality of living with and loving an addict. <span><br/></span><span><br/></span>Moving between fantasy and reality, past and present and inspired by equine therapy, the play explores the deepening bond between The Horse and The Woman: how they come together to negotiate their relationship, re-discover play and eventually heal each other in the process. An 80-minute high octane rollercoaster with stunning visuals and an immersive soundscape, 12 Litres 8800 Steps is for anyone seeking a silver lining in the dark.<span><br/></span><span><br/></span><span class=\"BoldText\">Content warning: addiction, alcoholism, mental health, panic attacks, drowning, death.</span><span><br/></span><span><br/></span><span class=\"BoldText\">Sensory warning: Loud, immersive sound</span><span><br/></span><span><br/></span><span><br/></span>
""";
  schema:startDate "2026-05-17T14:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/factorytheatre/files/1259ff12-bb6c-4427-bd44-37bfc1ec3815.jpg>;
  schema:location <https://spektrix.com/factorytheatre/location/1AHGJDSMMPLMPPGNLJBQVLBRSKVDLQRPP>;
  schema:offers _:78f1e3f00e524974ab72909aa5a3a4a9284;
  schema:duration "PT80M";
  schema:endDate "2026-05-17T15:20:00"^^xsd:dateTime .

_:78f1e3f00e524974ab72909aa5a3a4a9284 a schema:AggregateOffer;
