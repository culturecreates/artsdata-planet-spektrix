  schema:endDate "2026-05-09T20:45:00"^^xsd:dateTime .

_:d25bd24b203747b0805b2b5a2fe2a792257 a schema:AggregateOffer;
  schema:lowPrice "25.0";
  schema:priceCurrency "CAD" .

