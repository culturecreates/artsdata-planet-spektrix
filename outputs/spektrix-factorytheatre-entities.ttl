<http://www.spektrix.com/factorytheatre/event/135402APHSQTMJKPMTSTJNJSRRLPRNDPJ> a
    schema:Event;
  schema:name "Pain! The Musical";
  schema:description """
	<h2>A Workshop Presentation</h2><span><br/></span><span><br/></span>Witness the unique story of pain and the human experience come to life through this musical. What if pain could speak – and even sing? What advice would it have? Would people even listen? Combining comedy with compassion, this daring musical aims to give pain and those affected by it a voice.<span><br/></span><span><br/></span><span><br/></span>Content Warnings: Coarse language, drug and alcohol use referenced.<span><br/></span>Age Recommendation: 14+<span><br/></span><span><br/></span><span><br/></span>A limited number of complimentary tickets are available for those on the Ontario Disability Support Program (ODSP) or for anyone with financial difficulties. We want this show to be accessible to all!<span><br/></span><span><br/></span>To apply for your complimentary ticket, please email info@ThePainTruth.org
""";
  schema:startDate "2026-01-28T19:00:00"^^xsd:dateTime;
