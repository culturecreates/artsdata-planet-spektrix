<http://www.spektrix.com/factorytheatre/event/142802ACVSTMDGLPKJDDVQMBSLDKPPNPQ> a
    schema:Event;
  schema:name "Confessions of A Black Girl Who Should Know Better";
  schema:description """
	<h2>Created and performed by Trey Anthony</h2>Confessions of a Black Girl Who Should Have Known Better is not just a show—it’s an experience.<span><br/></span>Spend an unforgettable night with Trey Anthony as she takes you from script to stage in a raw, hilarious, and deeply personal journey through love, life, motherhood, and the lessons we swear we didn’t see coming. With her signature wit and fearless storytelling, Trey peels back the layers of what it really means to grow, to fall, to rise—and to finally tell yourself the truth.<span><br/></span><span><br/></span>This is comedy that hits home.<span><br/></span><span><br/></span>Music that moves your spirit.<span><br/></span><span><br/></span>Stories that will have you laughing one minute and catching your breath the next.<span><br/></span><span><br/></span>Uncensored. Emotional. Unapologetically real.<span><br/></span><span><br/></span>Come ready to laugh loud, feel deeply, and maybe even see yourself in the stories you didn’t know needed telling.<span><br/></span><span><br/></span><span class=\"ItalicText\">Age Recommendation: 17 +</span><span><br/></span><span class=\"ItalicText\">Duration: approx. 165 minutes</span><span><br/></span><span><br/></span>
""";
  schema:startDate "2026-05-28T19:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/factorytheatre/files/bc53871e-e4ff-4397-8dd9-dc41f1ca5707.jpeg>;
  schema:location <https://spektrix.com/factorytheatre/location/1AHGJDSMMPLMPPGNLJBQVLBRSKVDLQRPP>;
  schema:offers _:78f1e3f00e524974ab72909aa5a3a4a9299;
  schema:duration "PT180M";
  schema:endDate "2026-05-28T22:00:00"^^xsd:dateTime .

