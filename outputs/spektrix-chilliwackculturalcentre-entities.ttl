<http://www.spektrix.com/chilliwackculturalcentre/event/69401AHRLMSBQLVDQNDHQJHGMBCGHMNBC>
  a schema:Event;
  schema:name "Louisiana Hayride Show";
  schema:description """
	<h1>This is your last chance to take a trip down memory lane with this unique and incredibly entertaining musical celebration.</h1><span><br/></span>Join original Louisiana Hayride Show members Andrea Anderson, William Brookfield, Gil and Lori Risling, along with longtime members Derek Pulliam, Terry Hoknes and Jordan Perry as they celebrate 15 years of bringing this show to you! Come out for one last time to join in the celebration and say goodbye.<span><br/></span><span><br/></span>The Louisiana Hayride Show, with amazing world class tribute artists and live band will bring you back in time to when songs were meaningful, the words were understood, and the sound was pleasant.<span><br/></span><span><br/></span>Legendary stars will come to life before your eyes! You’ll think you’re at their concert when you see Patsy Cline, Lefty Frizzell, Loretta Lynn, Roy Orbison, Shania Twain, Crystal Gayle and Willie Nelson step on stage to sing their big hits, all in one incredible show.
""";
  schema:startDate "2025-09-11T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/1dd53f93-e498-4e86-930c-eefbf409fbd0.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36868172;
  schema:keywords "Tribute Band";
  schema:duration "PT60M";
  schema:endDate "2025-09-11T20:30:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36868172 a schema:AggregateOffer;
