<http://www.spektrix.com/chilliwackculturalcentre/event/4056AHGHVGRPLVTJQQPCBJVCTLCNLRTPT>
  a schema:Event;
  schema:name "La Vie en Rose";
  schema:description """
	<h1>Enchanting music for the harp and piano!</h1><span><br/></span>The creative and versatile harpist Janelle Nadeau will be joining The Bergmann Duo for a delightful, enchanting concert with a wide variety of music for harp and piano. The eclectic programme will feature audience favourites, such as Gabriel’s Oboe by Ennio Morricone, music from Bizet’s Arlésienne-Suite as well as a selection of popular songs, including Fly me to the Moon and La Vie en Rose. Janelle will showcase several of her harps featuring a wide range of colours and styles.
""";
