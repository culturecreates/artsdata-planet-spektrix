<http://www.spektrix.com/chilliwackculturalcentre/event/17401ARMGDGRGTJBKVPBLJVRHCKNDGPTT>
  a schema:Event;
  schema:name "Disney's Newsies";
  schema:description """
	<h1>Stop the presses and allow us to take you back in time to turn-of-the-century New York City, with Disney’s Newsies. </h1>This Tony-winning Broadway musical is the heart-warming tale of Jack Kelly, a charismatic newsboy filled with dreams of a better life, who rises as the leader of a group of orphaned, runaway, and dirt poor “Newsies.” When publishing giants raise distribution prices at the newsboys’ expense, Jack empowers Newsies from across the city to strike against the unfair conditions. Based on the real-life Newsboys Strike of 1899 in New York City, the strength of a unified community of young people inspires everyone to seize the day and fight for what’s right! It leaves you filled with hope that change can happen, as people stand together in the face of injustice.
""";
  schema:startDate "2025-05-21T19:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/acc3e2b4-c3e8-416b-9f7f-76ae9e786ecb.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36867930;
  schema:keywords "Musical Theatre";
  schema:duration "PT60M";
  schema:endDate "2025-05-21T20:00:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36867930 a schema:AggregateOffer;
  schema:lowPrice "0.0";
  schema:priceCurrency "CAD" .

