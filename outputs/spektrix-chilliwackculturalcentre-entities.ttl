<http://www.spektrix.com/chilliwackculturalcentre/event/169001AMGJSMHRSTNTHGVTJNGTPTTTMQB>
  a schema:Event;
  schema:name "Bands of the Valley";
  schema:description """
	<h1>Bands of the Valley – A Night of Live Local Music</h1><span><br/></span>Join us for Bands of the Valley on July 11 at the Chilliwack Cultural Centre for an exciting night of live music featuring talented local bands from across the Fraser Valley. With a mix of high-energy performances, dancing, and a welcoming community atmosphere, this event is all about supporting local artists and bringing people together through live music.<span><br/></span><span><br/></span>Featuring performances by Retrofit, Big Deal, and The Bobby’s, the night will showcase a variety of sounds and styles in an intimate cabaret-style setting. Guests can enjoy great music, drinks from the venue bar, raffle giveaways, and a memorable night celebrating local talent in the community.<span><br/></span><span><br/></span><span class=\"BoldText\">NOTE:</span> This event is general seating and standing. Seating includes 92 seats at tables and 26 chairs off to the side. Additional standing room is available at cocktail tables. The room will also feature a dance floor and a floating bar.
""";
  schema:startDate "2026-07-11T19:00:00"^^xsd:dateTime;
