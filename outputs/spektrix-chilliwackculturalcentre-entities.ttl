<http://www.spektrix.com/chilliwackculturalcentre/event/169401APDTBKPSDJCCNKCKLJCMQDCCDDR>
  a schema:Event;
  schema:name "Cascadia Remembers";
  schema:description """
	<h1>Join the Cascadia Wind Ensemble for a moving and heartfelt evening of music as they honour the service and sacrifice of Canada’s veterans.</h1><span><br/></span>This special Remembrance concert marks the 100th anniversary of the Royal Canadian Legion, celebrating a century of support for those who have served our country.<span><br/></span><span><br/></span>Through powerful and reflective music, Cascadia will be joined by distinguished guests including acclaimed piper Marcus Range and the beautiful voices of Voce Destino, creating an atmosphere of remembrance, gratitude, and unity. Experience an evening of stirring melodies, solemn tribute, and inspiring collaboration as we pause to remember.
""";
  schema:startDate "2026-11-10T19:30:00"^^xsd:dateTime;
