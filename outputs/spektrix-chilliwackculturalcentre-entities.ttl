<http://www.spektrix.com/chilliwackculturalcentre/event/93601ASMSRSHLGTLHJVMLSMKVNQKJMQCR>
  a schema:Event;
  schema:name "La Valse";
  schema:description """
	<h1>La Valse</h1><span><br/></span>The Waltz became the most popular and significant dance of the 19th century, and many great composers have been inspired by its characteristic features, creating some of their most inspired and beloved works.<span><br/></span><span><br/></span>For this final concert of the season, we have chosen some of our favourite two-piano repertoire, including Liszt’s Mephisto-Waltz, Ravel’s La Valse, Copland’s Saturday Night Waltz as well as William Bolcom’s witty Ragtime-Fantasy The Serpent’s Kiss.
""";
  schema:startDate "2026-03-14T14:00:00"^^xsd:dateTime;
