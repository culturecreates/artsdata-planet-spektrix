<http://www.spektrix.com/chilliwackculturalcentre/event/174601ABBQGHNRPQMCRQRJDPTJBBSSSVB>
  a schema:Event;
  schema:name "The Alan Jackson Experience";
  schema:description """
	<h1>Aaron Halliday, a two-time ISSA Entertainer of the Year Award winner and Nashville recording artist, presents an internationally recognized tribute to Alan Jackson, featuring CCMA Award-winning musicians.</h1><span><br/></span>This show is an incredible recreation of an Alan Jackson concert, boasting an authentic look, stage presence, and sound that will transport you to the real thing. Prepare yourself for an energetic and entertaining performance that will have you singing along to 'Good Time' and reminiscing about the past with 'Remember When.'
""";
