<http://www.spektrix.com/chilliwackculturalcentre/event/111201ALQPSSKHLLBKDSLDDDJBBGHKGVV>
  a schema:Event;
  schema:name "Photography Perspectives With Brooke Cote";
  schema:description """
	Meet our Artist-In-Residence, photographer Brooke Cote! Learn about her evocative approach to subject matter and in open group activities and demonstrations create a mood for self-portraits, live models, and still-life. No cameras are necessary, but you may wish to bring something to take notes with.
""";
  schema:startDate "2026-01-21T18:30:00"^^xsd:dateTime;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
