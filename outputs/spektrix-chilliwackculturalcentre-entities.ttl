<http://www.spektrix.com/chilliwackculturalcentre/event/5801ANBQVBLJQKVGKMVQVKJKLJQMKBTVN>
  a schema:Event;
  schema:name "Lunatics On The Grass";
  schema:description """
	<h1>This 9-member group of veteran professional musicians began in 2019, performing the music of one of modern culture's most phenomenal classic rock bands. </h1><span><br/></span>Drawing from the immense Pink Floyd catalog and the brilliant solo projects of David Gilmour and Roger Waters, Lunatics On The Grass brings a tour de force to the stage.<span><br/></span><span><br/></span>After the COVID disruption and several changes to their lineup, the band has been relentlessly rehearsing since the summer of 2024.<span><br/></span><span><br/></span>In preparation for their first performance since 2020, the Lunatics have added visually stunning animated graphics, and a light show display that's sure to create an unforgettable symphonic psychedelic evening.
""";
  schema:startDate "2025-03-07T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/87bcfa1f-020a-4407-a954-f71fcd9c83b5.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
