  a schema:Event;
  schema:name "May the 4th Be with You";
  schema:description """
	<h1>The Chilliwack Metropolitan Orchestra is delighted to bring you a concert of music from the Star Wars Universe-the original trilogy, the sequels, and more! </h1>It will feature two brand new arrangements of music from Rogue One and Ahsoka. Bring your costumes and enjoy the battles! Tickets will sell fast, so be sure to get your soon.
""";
