  a schema:Event;
  schema:name "Make Some Noise (8-11)";
  schema:description """
	This is your chance to learn how to be loud with a crowd! Learn the basic techniques of body percussion and then compose and choreograph a routine to some of your favourite songs! When registering your child, please indicate which child will be attending in the order notes. Please note that we have updated requirements for registration, behaviour policy, accessibility limitations, and student waivers.
""";
