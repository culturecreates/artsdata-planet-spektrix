<http://www.spektrix.com/chilliwackculturalcentre/event/73801ANBCGMJCHDPQBLMBCJTMLMHSQQHQ>
  a schema:Event;
  schema:name "Cascadia Remembers 2025";
  schema:description """
	<h1>Cascadia Remembers: Poppies, Tulips and Maple Leaves</h1><span><br/></span>A Remembrance concert that focuses, this year, on the 80th anniversary of the end of WW II, and in particular the role that Canadians played in liberation of Europe.<span><br/></span>Featuring: Chilliwack Elementary Schools Choir, and our guest piper, Marcus Range.
""";
