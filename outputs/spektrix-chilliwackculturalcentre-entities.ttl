<http://www.spektrix.com/chilliwackculturalcentre/event/88201ARGKKMLLRVMKPHJVBMLTPPGVHJQL>
  a schema:Event;
  schema:name "Let's Go Surfin'! 2025";
  schema:description """
	<h1>Get ready to be swept away by the timeless melodies of the Beach Boys! </h1><span><br/></span>Join us for a nostalgic evening filled with their iconic hits and concert favorites. Let’s Go Surfin is performed by BACKBEAT, Canada's most authentic musical tribute to the 60's. They nail the incredibly intricate Beach Boys harmonies perfectly! All the genius of Brian Wilson’s songwriting and studio wizardry blossoms on stage in a spectacular musical salute to one of the greatest pop groups of all time!
""";
  schema:startDate "2025-10-22T19:30:00"^^xsd:dateTime;
