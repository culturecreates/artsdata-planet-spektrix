_:1290a8eb9d794355b3e34223272b36868505 a schema:AggregateOffer;
  schema:lowPrice "22.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/chilliwackculturalcentre/event/71801ABVJVLDBDPJBNLJVMTCQQRSJHMBM>
  a schema:Event;
  schema:name "VIMFF 2026";
  schema:description """
	<h1>An extravaganza of high-octane and hair-raising cinema blending a love of adventure with pioneering film-making!</h1><span><br/></span>The Vancouver International Mountain Film Festival – Best of Fest is coming to Chilliwack! Driven by passion for film and the outdoors, VIMFF annually selects unique, award-winning films to tour across Canada! Whether you love nature and the outdoors or are a cinephile at heart, VIMFF promises a night of phenomenal filmmaking excellence! Enjoy a blend of love for adventure with pioneering filmmaking bringing us a night packed with energy, exploration, and some seriously amazing athleticism!
""";
  schema:startDate "2026-03-13T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/b5382405-f925-4a5c-a979-16d7e3d8e18a.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
