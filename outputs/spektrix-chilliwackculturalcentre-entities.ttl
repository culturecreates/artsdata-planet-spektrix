  a schema:Event;
  schema:name "Clay Exploration";
  schema:description """
	Step into our professional clay studio and explore the art of sculpture! Clay Exploration is all about creativity and craftsmanship, where students will learn hand-building techniques and work with professional tools to create their own one-of-a-kind clay pieces. This is the perfect class for those looking to expand their skills in the world of clay art!
""";
