<http://www.spektrix.com/chilliwackculturalcentre/event/83402AJTKBBRMRSBNLQBJBQRPKCRVCVNV>
  a schema:Event;
  schema:name "Dungeons & Dragons One-Shot Adventure";
  schema:description """
	Have you always wanted to try your hand at D&D, but can't find a group? Come out and stretch your creative muscles in a fun three-hour adventure with an experienced guide! Through gameplay, learn to improvise, choose a provided pre-generated character to bring to life, and craft your story - no previous gaming experience necessary, just your imagination! All supplies included and all participants take home their own set of dice!
""";
  schema:startDate "2025-12-09T18:00:00"^^xsd:dateTime;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
