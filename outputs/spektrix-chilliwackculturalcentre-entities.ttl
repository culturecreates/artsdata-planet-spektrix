<http://www.spektrix.com/chilliwackculturalcentre/event/88601AQDJSGGLTSQJVGQGKCVNSRNQVTBJ>
  a schema:Event;
  schema:name "The Howl Masquerade";
  schema:description """
	<h1>Everybody sings & everybody howls in this lighthearted one-hour family concert.</h1><span><br/></span>A colourful and animated choir of young, costumed howlers join Norman Foote with their singing, sound effects, animal sounds, zombie groans, cackling witches, ghostly boos and spontaneous laughter. (note... it’s not a scary show… only fun) The concert combines Norman’s songs, humour and props all to great effect.<span><br/></span><span><br/></span>Joining Norman are singers from Promontory Heights & Squiala Elementary.<span><br/></span><span><br/></span>Norman Foote has performed throughout North America and beyond in theatres and festivals. He is written and recorded for such companies such as Disney records, CBC, YTV and many others.<span><br/></span><span><br/></span>His song writing and recordings have garnished several awards, including a Juno award. WCMAs and Parents Choice gold.
""";
  schema:startDate "2025-10-27T19:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/135e0660-7e0b-44ea-9ad4-025e5463a5b3.jpg>;
