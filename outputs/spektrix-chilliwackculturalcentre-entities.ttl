<http://www.spektrix.com/chilliwackculturalcentre/event/178401ARDJJBBKCKTBLLQSDSVSKTQPKDQ>
  a schema:Event;
  schema:name "The Great Canadian Last Waltz";
  schema:description """
	<h1>The Great Canadian Last Waltz celebrates the timeless and brilliant music of The Band and their final legendary concert, “The Last Waltz”, while shining a spotlight on the rich tradition of Canadian-made original songs that continue to shape our culture.</h1><span><br/></span>2026 marks the 50th Anniversary of The Last Waltz.<span><br/></span><span><br/></span>This powerful show brings together an all-star lineup of professional touring artists, songwriters, and legendary musicians who proudly call Canada home. Spanning generations and crossing the boundaries of genres, this cast is united by a common bond- the music itself, the world it brings together, and the unforgettable songs it inspires.
""";
  schema:startDate "2026-11-29T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/8299fd77-3a97-4538-b384-9a8232b9bb28.jpg>;
