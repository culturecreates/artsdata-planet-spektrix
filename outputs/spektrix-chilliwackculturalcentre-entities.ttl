<http://www.spektrix.com/chilliwackculturalcentre/event/101001ASRCJQGCSBLJCPNPQQRRGSLJCLH>
  a schema:Event;
  schema:name "Spring Passion";
  schema:description """
	<h1>Celebrate the season of renewal with an unforgettable Spring concert featuring two exhilarating masterpieces.</h1><span><br/></span>Mendelssohn’s radiant Symphony No. 5 “Reformation” soars with grandeur and lyricism, weaving noble chorales and vibrant themes into a work of spiritual and emotional depth. Paired with Rimsky-Korsakov’s dazzling Russian Easter Festival Overture — a brilliant tapestry of luminous orchestral colors and festive energy — this program promises an afternoon of uplifting music that captures both reflection and jubilation.
""";
  schema:startDate "2026-03-29T15:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/2db5e96f-2079-4e42-aa25-639cb26e0d91.jpg>;
