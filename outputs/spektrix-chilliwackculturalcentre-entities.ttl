<http://www.spektrix.com/chilliwackculturalcentre/event/180201ARDPVDMGSBDRHNKHPMBCHGHNCHQ>
  a schema:Event;
  schema:name "An Acoustic Evening with William Prince";
  schema:description """
	<h1>William Prince brings his unmistakable voice and deeply moving songwriting to the stage in support of his latest album, Further from the Country.</h1><span><br/></span>A two-time JUNO Award winner, and decorated musician, Prince creates a rare connection with audiences—his performances unfolding as thoughtful, story-rich experiences that linger long after the final note.
""";
