<http://www.spektrix.com/chilliwackculturalcentre/event/51001ARVGTVPPNTBQGVCQJBVQPDQSJLSM>
  a schema:Event;
  schema:name "Life to the Limit Screening";
  schema:description """
	“Life to the Limit” invites audiences to step into the lives of two Kyiv filmmakers who left behind an Oscar nominated documentary to volunteer on Ukraine’s eastern front. Through their own footage and memories, the film reveals how the russia Ukrainian war unfolded in the 21st century, exposing the human cost of conflict and the resilience that emerges from tragedy. The original film, “Winter on Fire,” earned an Academy Award nomination for Best Documentary Feature, underscoring the filmmakers’ dedication and impact.
""";
  schema:startDate "2025-06-20T17:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/96c99e6d-26c1-46c8-8454-87f13e4f4809.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
