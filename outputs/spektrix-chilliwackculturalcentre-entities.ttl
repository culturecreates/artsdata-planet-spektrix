  a schema:Event;
  schema:name "A Night in Vienna-Strauss Ball";
  schema:description """
	<h1>The CMO is putting on a Gala fundraiser at the Evergreen Hall next to the Cultural Centre on Saturday the 23rd of May at 5pm.</h1><span><br/></span>There will be a full orchestra, dancing to waltzes and polkas, a buffet dinner and a live auction. Dress up in your best and come for a fun filled evening.
""";
