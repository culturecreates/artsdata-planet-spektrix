  a schema:Event;
  schema:name "The 2025 Chillies Awards";
  schema:description """
	<h1>Chilliwack’s Premiere Arts Awards</h1><span><br/></span>“The Chillies™” are an awards program like no other, recognizing Chilliwack’s artists for their incredible achievements. The Chilliwack Arts Council, The Chilliwack Progress, chillTV & chillsounds have joined forces to feature the highest achievers in 11 categories:<span><br/></span><span><br/></span>Best Stage Dramatic Performance<span><br/></span>Best Stage Musical or Comedy Performance<span><br/></span>Film or Video Production of the Year<span><br/></span>Visual Arts Excellence<span><br/></span>Musician of the Year<span><br/></span>Top Writer<span><br/></span>Emerging Artist of the Year<span><br/></span>Arts Education Champion Award<span><br/></span>Cultural Achievement Award<span><br/></span>Public Art of the Year<span><br/></span>Uber-Achiever Award
""";
