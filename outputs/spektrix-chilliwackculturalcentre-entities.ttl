<http://www.spektrix.com/chilliwackculturalcentre/event/69001AQHRKJGBJLJBVQPKPMTSHNLBBLGD>
  a schema:Event;
  schema:name "Upright Beats";
  schema:description """
	<h1>Whether it’s jazz or classical music, this concert is for everyone!</h1><span><br/></span>Joined by award-winning Jazz bassist, composer, and improviser Jodi Proznick, the Bergmann Duo embarks on another inspiring musical journey through classical and modern composers! From Bach and Mozart to Jobim’s famous Girl from Ipanema and Ukrainian folksong What a Moonlight Night, this concert will have you tapping your toes. Step out and enjoy an evening of Upright Beats!
""";
