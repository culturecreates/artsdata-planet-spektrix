<http://www.spektrix.com/chilliwackculturalcentre/event/148601AKCGDJRJBKRGHPJKSKDQHKHLJRV>
  a schema:Event;
  schema:name "Winter Harp";
  schema:description """
	<h1>Celebrate Christmas with the Enchanting Sounds of Winter Harp.</h1><span><br/></span>One of BC’s most beloved holiday concerts, Winter Harp takes you on a magical journey you will never forget. Harps, singers, medieval instruments, flutes, violin and percussion combine for a hauntingly beautiful concert of pure Christmas magic. Known for sold-out houses and standing ovations, Winter Harp is a “must-see” ticket on the holiday calendar. Join this world-class ensemble of singers, harps, flute, violin, medieval instruments and percussion for a concert of heartwarming carols and stories in celebration of Christmas. The musicians, in rich medieval attire, perform on a stage set with magnificent backdrops of cathedral and snow that will whisk you to a land of pure magic.
""";
  schema:startDate "2026-12-08T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/9a45ce3c-ecaa-4a40-925b-fd1eb8bd58ce.jpg>;
