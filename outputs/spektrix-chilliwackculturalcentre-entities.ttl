<http://www.spektrix.com/chilliwackculturalcentre/event/181001ATMRVKTCRDBKKTKLKBKNCGJRLSH>
  a schema:Event;
  schema:name "Dr. Mike Corman";
  schema:description """
	<h1>Do We Need More Doctors, Nurses, and Paramedics? Look Upstream!</h1><span><br/></span>This thought-provoking presentation explores how sociology can help us better understand and perhaps solve today’s healthcare challenges. Moving beyond the common assumption that the answer is simply more doctors, nurses, and paramedics, it examines how an “upstream” approach may reveal different and more effective solutions to complex issues in health and social care.
""";
  schema:startDate "2026-11-12T10:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/be2d9c19-5dfa-4aec-a682-2d1e07d2c69b.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36867938;
