  schema:duration "PT60M";
  schema:endDate "2026-09-09T20:30:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36868503 a schema:AggregateOffer;
  schema:lowPrice "0.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/chilliwackculturalcentre/event/66201ANBJCCNMNTBQVCLNSBCLHRLCHCHL>
  a schema:Event;
  schema:name "Vancouver Cello Quartet 2025";
  schema:description """
	<h1>The Vancouver Cello Quartet returns with a phenomenal concert inspired by Italy’s musical legacy! </h1><span><br/></span>From the ornate beauty of Baroque to the romance of modern Italian film scores, the Vancouver Cello Quartet presents A Taste of Italy, a richly textured program that will take you on a dynamic journey through centuries of Italian artistry. Comprising of four master cellists, the Vancouver Cello Quartet promises an evening of splendor with their blend of classic and contemporary. With every concert, they create an eclectic repertoire and shape the program to their audience’s taste, promising a stellar evening for music lovers of all kinds.
""";
