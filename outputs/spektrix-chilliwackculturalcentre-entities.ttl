<http://www.spektrix.com/chilliwackculturalcentre/event/3657ARVGDQRVSHSGQSBRGNHPGQLSDTGBQ>
  a schema:Event;
  schema:name "Cinema Classics";
  schema:description """
	<h1>An evening of epic, thrilling, and romantic film music from westerns to dramas to science fiction classics!</h1><span><br/></span>Join the Calgary Youth Orchestra for an evening of magical movie music. Known for their exceptional talent and youthful energy, these young musicians deliver stirring performances under their esteemed conductor Edmond Agopian. The program features a captivating mix of iconic film scores that will transport you to the magical world of cinema. Experience the thrill of live orchestral music as the orchestra brings to life the soundtracks of your favorite films.<span><br/></span><span><br/></span>Don’t miss this enchanting evening of cinematic symphony, perfect for audiences of all ages!
""";
  schema:startDate "2025-08-02T19:30:00"^^xsd:dateTime;
