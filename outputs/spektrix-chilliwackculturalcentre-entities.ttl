  schema:priceCurrency "CAD" .

<http://www.spektrix.com/chilliwackculturalcentre/event/176201ANLHLNRPJJGGPMMRCPRLLCQRKBR>
  a schema:Event;
  schema:name "VIMFF 2027";
  schema:description """
	<h1>Heart‑Pounding Adventure. Breathtaking Cinema. One epic night!</h1><span><br/></span>Outdoor enthusiasts and film lovers alike are invited to an unforgettable evening of world‑class short films from one of Canada’s most celebrated film festivals. Showcasing the very best in mountain culture, adventure storytelling, and environmental filmmaking, this exhilarating screening delivers heart‑pounding moments, breathtaking landscapes, and stories that truly stir the soul. With incredible door prizes up for grabs, it’s the perfect opportunity to ignite inspiration for your next outdoor adventure. This selection of films captures the raw spirit of exploration, resilience, and humanity’s profound connection to the natural world. From high‑stakes alpine expeditions and extreme sports to intimate, moving portraits of perseverance, VIMFF offers a powerful cinematic journey that will leave you inspired to embrace the wild and push your own limits.
""";
  schema:startDate "2027-04-21T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/872a2d91-7075-419c-bba5-8c190fd60e16.jpg>;
