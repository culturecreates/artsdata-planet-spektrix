<http://www.spektrix.com/chilliwackculturalcentre/event/145001APQNTPLNQTJSGMGPKLQMMNPDVKG>
  a schema:Event;
  schema:name "Little Shop of Horrors";
  schema:description """
	<h1>A Monster-Sized Musical That Devours the Stage - and Your Heart!</h1><span><br/></span>Little Shop of Horrors is a delicious Broadway smash that’s so big, you’ll have to see it twice! This monster of a musical has devoured the hearts of audiences for over 30 years as one of the longest running Off Broadway hits. Bursting with jaw dropping special effects, unforgettable characters, and a tender love story at its core, the show blends comedy, horror, and heart in irresistible fashion. Featuring a fabulous, toe tapping sixties style score by Alan Menken with a witty and wildly entertaining book and lyrics by Howard Ashman, this sci fi spoof delivers nonstop fun, thrills, and laughs. It’s a monster sized production that devours the stage, and your heart, leaving audiences hungry for more.<span><br/></span>
""";
  schema:startDate "2027-05-08T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/2acd7363-1dd0-4b3e-b54a-6076386c7aad.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36868106;
