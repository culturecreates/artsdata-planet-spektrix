<http://www.spektrix.com/chilliwackculturalcentre/event/3968AMGSPJLQTNQGGMGLJMVSLSKJQPRJC>
  a schema:Event;
  schema:name "Ring of Fire";
  schema:description """
	<h1>The Music of Johnny Cash</h1><span><br/></span>Let the songbook of the iconic storyteller Johnny Cash guide you on a journey of struggle and success, love and redemption. Brought to life by a talented collection of singers and musicians, this theatrical concert gets to the heart of Cash’s unique life story and connects it with universal experiences in songs such as “I Walk the Line,” “Folsom Prison Blues,” “Country Boy,” and “A Boy Named Sue.”
""";
