<http://www.spektrix.com/chilliwackculturalcentre/event/105401APRJVMGJLHSJCNQLVPBJJLBQLJQ>
  a schema:Event;
  schema:name "Perspective Drawing";
  schema:description """
	Find out how easily perspective can be mastered in this explorative class. Explore perspective drawing through exercises in one-point and two-point perspective. Explore how objects diminish in size and how to use shading to make objects look solid. Students will utilize all of this to create a finished drawing. 
""";
  schema:startDate "2026-01-14T13:00:00"^^xsd:dateTime;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:keywords "Art Classes";
  schema:duration "PT120M";
