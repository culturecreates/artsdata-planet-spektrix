<http://www.spektrix.com/chilliwackculturalcentre/event/94401ARDLRHSVRSCRMVBGVLRHHLMQHDLL>
  a schema:Event;
  schema:name "Drag in the Wack 2025";
  schema:description """
	<h1>Get ready for a dazzling night of glamour, music, and unapologetic self-expression with Drag in the Wack! </h1><span><br/></span>This electrifying performance will celebrate the artistry of drag with bold costumes, high-energy lip-syncs, hilarious banter, and jaw-dropping talent. Whether you’re a longtime drag fan or experiencing the magic for the first time, Drag in the Wack promises an evening of empowerment, inclusivity, and pure entertainment. Cale’s magnetic stage presence and unique flair will keep you captivated from start to finish, creating a show that’s as heartfelt as it is fabulous. Step into a world where creativity knows no bounds — because in Chilliwack, drag has never looked this good!<span><br/></span>
""";
  schema:startDate "2025-10-20T19:30:00"^^xsd:dateTime;
