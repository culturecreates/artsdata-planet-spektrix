  schema:duration "PT60M";
  schema:endDate "2026-11-12T11:00:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36867938 a schema:AggregateOffer;
  schema:lowPrice "0.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/chilliwackculturalcentre/event/74201ACMVPHLJKTRRBJKKLCTRPJVKGDGS>
  a schema:Event;
  schema:name "Dracula";
  schema:description """
	<h1>Dracula.  Unending life... Unending love. A Love Story tells the classic tale of Bram Stoker’s novel.</h1><span><br/></span>This original adaptation written by local writer, Susan E. Newbury, depicts Dracula as a man torn between his beastly curse and his search to find love again. This period piece is sure to whisk you away to a world where superstition is reality, the vampire does exist, and love can find its way into the darkest of hearts. Audience members will enjoy this intimate, dark, immersive theatrical display chocked full of supernatural forces and special effects. 
""";
  schema:startDate "2025-10-09T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/bdb1bb54-46b7-440f-a3f5-62f337200baf.jpg>;
