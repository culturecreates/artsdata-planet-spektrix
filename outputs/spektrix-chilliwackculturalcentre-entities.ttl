<http://www.spektrix.com/chilliwackculturalcentre/event/128801AMGHJTTHPDLLPSDCNLTCJPRMHPT>
  a schema:Event;
  schema:name "He Said, She Said Comedy Show";
  schema:description """
	<h1>Get ready for a night of sharp comedy, high energy, and wildly relatable stories as HE SAID, SHE SAID hits the stage on December 27th!</h1><span><br/></span>This powerhouse lineup brings together some of the strongest comedic voices in the country:<span><br/></span><span><br/></span>Starring:<span><br/></span>Ivan Decker — Netflix, Conan, Juno Award Winner<span><br/></span>Jane Stanton — CBC, Just For Laughs & Winnipeg Comedy Festival audience favorite<span><br/></span>Sophia Johnson — CBC & International New Zealand Comedy Star<span><br/></span><span><br/></span>Expect clever takes, big punchlines, and the hilarious clash of his and hers on one stage. From relationships to everyday chaos, this lineup delivers the kind of comedy that hits home and keeps you laughing long after the show ends.<span><br/></span>
""";
  schema:startDate "2025-12-27T20:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/5acdc108-4d6b-41d1-a531-699665247fa1.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36868028;
  schema:keywords "Comedy";
  schema:duration "PT60M";
  schema:endDate "2025-12-27T21:00:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36868028 a schema:AggregateOffer;
  schema:lowPrice "21.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/chilliwackculturalcentre/event/20201AVQHKKMVCNSSQSPNTVCQPQCKBBPV>
  a schema:Event;
  schema:name "Hearts of Gold Gala";
  schema:description """
	<h1>Gala Fundraiser for Childhood Cancer. Improving the lives of children with cancer.</h1><span><br/></span>*General admission to the Lobby & Rotary Hall at 6pm. Presentations and live auction in the HUB International Theatre at 8:30pm. Dancing and cocktails 10pm.<span><br/></span><span><br/></span>Cancer is the #1 cause of death in children, more than all other diseases combined! Yet only 5% of all cancer funding is directed to childhood cancers. This needs to change and with your help it can! Proceeds from the gala go to support the Michael Cuccione Childhood Cancer Research Program at BC Children’s Hospital, Children’s Cancer Therapy Development Institute and UCLA’s pediatric sarcoma research program.<span><br/></span><span><br/></span>The Hearts of Gold gala fundraiser for childhood cancer research is sure to be a night to remember! One of Chilliwack's A-LIST of favourite fundraisers, there will be lots to see and do! Plenty to eat and drink with hors d’oeuvres served by top chef Tammy Wood, pastries from BeNanna Bakery and some up-close magic performed by Damien Carriere (Mobile Magic) while you eat, drink and mingle.  Test your luck in the mini casino, join in the high energy, fast paced live auction and finish the night off with some dancing.
""";
  schema:startDate "2025-03-15T18:00:00"^^xsd:dateTime;
