<http://www.spektrix.com/chilliwackculturalcentre/event/115201AVMKJPGCJLKJHPRGCGJSHLPKDPC>
  a schema:Event;
  schema:name "Drag in the Wack ";
  schema:description """
	<h1>Settle in for an evening of laughter with Cale Tian performing as Wan-Ting Moi in Drag in the Wack: Love, Lust & Lipstick Lines!</h1><span><br/></span>Alongside other Queens and Kings, Wan-Ting Moi promises an evening of empowerment, inclusivity and pure entertainment. Celebrate the artistry of drag with bold costumes, high-energy lip-syncs, hilarious banter, and jaw-dropping talent!
""";
  schema:startDate "2026-02-13T19:30:00"^^xsd:dateTime;
