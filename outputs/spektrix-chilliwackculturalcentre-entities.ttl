<http://www.spektrix.com/chilliwackculturalcentre/event/69801ACHMQQPHNNNRPKGGCKPVPDJPPBTJ>
  a schema:Event;
  schema:name "True North";
  schema:description """
	<h1>The Chilliwack Metropolitan Orchestra invites you to an afternoon of music celebrating the incredible composers of Canada with True North. </h1><span><br/></span>Dedicated to performing high quality symphony concerts for the Fraser Valley, the CMO has once again prepared another excellent concert with music and stunning visuals from coast to coast! Explore what Canada has to offer with pieces from Godfrey Ridout and Christopher Tyler Nickel. Featuring skilled saxophonist Julia Nolan for a special appearance in Hintersteininger’s Concerto for Saxophone, this concert invites you to celebrate the sights and sounds of Canada!
""";
  schema:startDate "2025-10-26T15:00:00"^^xsd:dateTime;
