<http://www.spektrix.com/chilliwackculturalcentre/event/150604AGGCTPLRGBCJNGJNQQGSGQHGGPT>
  a schema:Event;
  schema:name "Let's Make A Mask (5-7)";
  schema:description """
	Make a mask and you can become anything – a bird, an alien, even a wild animal! Grab your scissors and most colourful paints and start creating. When registering your child, please indicate which child will be attending in the order notes. Please note that we have updated requirements for registration, behaviour policy, accessibility limitations, and student waivers.
""";
  schema:startDate "2026-07-20T11:10:00"^^xsd:dateTime;
