<http://www.spektrix.com/chilliwackculturalcentre/event/68602AVRSPNTBNBBKGNCCBVJSBBMSHPSS>
  a schema:Event;
  schema:name " Make A Zine (11-15)";
  schema:description """
	What is a zine? A zine (short for magazine) is a small, self-published book that anyone can create about anything they are interested in! You will learn how to create content, design a layout, formatting, and bind it all together. Everyone will leave at the end of the week with a single-sheet zine of their very own that they can share with friends. When registering your child, please indicate which child will be attending in the order notes. Please note that we have updated requirements for registration, behaviour policy, accessibility limitations, and student waivers.
""";
  schema:startDate "2025-08-11T13:00:00"^^xsd:dateTime;
