<http://www.spektrix.com/chilliwackculturalcentre/event/155201ASVRJVBHKTKVHKRVMGNLSDBJDLD>
  a schema:Event;
  schema:name "Uncaged Soirée";
  schema:description """
	<h1>A free public event inspired by Birdy </h1><span><br/></span>Let the evening take flight.<span><br/></span><span><br/></span>Presented alongside the November 13 performance of Birdy, the Uncaged Soirée is a free public gathering that invites the community into an atmospheric celebration of movement, sound, flight, and transformation.<span><br/></span><span><br/></span>Throughout the evening, the lobby will come alive with evocative bird sounds, curated activations, and live music, creating an immersive atmosphere that echoes the beauty, tension, and sense of freedom at the heart of Birdy. Guests are also invited to uncage their creativity and come dressed to inspire, adding their own sense of colour, character, and imagination to the evening.<span><br/></span><span><br/></span>Whether attending the performance or simply joining for the soirée, everyone is welcome to connect, linger, and experience the Centre in a new way.<span><br/></span><span><br/></span>The Uncaged Soirée offers an open invitation to gather, reflect, and celebrate the power of performance, community, and creative expression taking flight.
""";
  schema:startDate "2026-11-13T20:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/4dd3e49d-ef9d-4084-8e11-e8547a3fcfbe.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36868482;
  schema:keywords "Festival";
  schema:duration "PT60M";
  schema:endDate "2026-11-13T21:30:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36868482 a schema:AggregateOffer;
  schema:lowPrice "0.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/chilliwackculturalcentre/event/168401ACBSGSQPQTSMDSSDKNVBHHHJPJB>
  a schema:Event;
  schema:name "Unearthed";
  schema:description """
	<h1>Local performers \"The Valley Babes\" are bringing \"Unearthed: A Modern Song Cycle\" to the Chilliwack Cultural Centre.</h1><span><br/></span>\"Unearthed\" uses song, storytelling, movement, and design to explore the cycles of control and freedom that are felt as a part of the feminine experience. Using earth, air, fire, and water as the base for song choice in the context of the theme for this Modern Song Cycle, the set list's 'language' of song ranges the Spectrum from Lady Gaga's \"Disease\" to Canadian Choral Composer Katerina Gimon's SOCAN Young Composers Competition Winning \"Elements\".
""";
  schema:startDate "2027-05-16T14:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/1a39d0d4-44b1-4537-98c7-3d7c4a8d47a0.jpg>;
