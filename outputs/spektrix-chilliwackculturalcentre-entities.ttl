<http://www.spektrix.com/chilliwackculturalcentre/event/168402ANKDBDCSMSSMKTQVVKVMKRGKVCT>
  a schema:Event;
  schema:name "A History of Motown";
  schema:description """
	<h1>A History of Motown is a thrilling journey through the legends, chart topping hits, and unforgettable stories that shaped an era of music.</h1><span><br/></span>Experience the soulful sound of Motown like never before with award winning powerhouse Krystle Dos Santos & Band. Following sold out shows and overwhelming audience response, A History of Motown is more than a concert. It’s a full on celebration. Audiences are invited to get on their feet, dance, and sing along as Krystle leads a high energy musical journey through the iconic songs that defined a generation. From the infectious grooves of The Supremes to the timeless brilliance of Stevie Wonder, Dos Santos brings Motown’s magic to life with unforgettable vocals, magnetic stage presence, and an electric, feel good atmosphere. Come ready to move, groove, and relive the music that changed the world.<span><br/></span>
""";
  schema:startDate "2026-11-20T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/bea62b97-ab0e-49c3-8219-de528cf2030b.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36867439;
