<http://www.spektrix.com/chilliwackculturalcentre/event/108801ALCMMPSBQHKPPPTSVMHCRCNRPVS>
  a schema:Event;
  schema:name "Pen and Ink Drawing - Wild Animals";
  schema:description """
	Welcome to a simpler world where everything is black and white. We will explore composition in the rectangle to create an interesting design. Cross-hatching and stippling techniques with pen will be used to develop values and form. We will use India ink to create dramatic backgrounds to complete our compositions. 
""";
  schema:startDate "2026-04-07T18:30:00"^^xsd:dateTime;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
