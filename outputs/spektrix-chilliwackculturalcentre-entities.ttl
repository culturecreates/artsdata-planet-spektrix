<http://www.spektrix.com/chilliwackculturalcentre/event/49001AHJBVTCVBRMRMLMCJSNSSQLBRQJR>
  a schema:Event;
  schema:name "Pisuwin";
  schema:description """
	<h1>From award-winning director and choreographer Igor Dobrovolskiy and multi-disciplinary artist Nipahtuwet Naka Wespahtuwet Possesom Paul, comes Pisuwin, an epic story-ballet based on a Wolastoq tale. </h1><span><br/></span>This visually stunning, multi-disciplinary piece pushes audiences to confront topics like greed and alienation while inspiring us to take a different path; one of connection, community, and wholeness. Tradition falls headfirst into the contemporary, as ballet and Wolastoq visual motifs of the spiritual and natural world blends and clashes with electronic sound, industrial landscapes, and digital projection. Pisuwin asks you to reflect on the current state of our world, illuminating a path to wholeness and rebalance.
""";
  schema:startDate "2025-11-10T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/1cb9250b-979b-421b-9007-ccaf5b42d385.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36868292;
  schema:keywords "Dance";
  schema:duration "PT145M";
  schema:endDate "2025-11-10T21:55:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36868292 a schema:AggregateOffer;
