<http://www.spektrix.com/chilliwackculturalcentre/event/171002AJTRPHMCJJGNLMMCPDLMRMVKKGQ>
  a schema:Event;
  schema:name "Ella Wishes You a Swinging Christmas";
  schema:description """
	<h1>A Joyful Swinging Christmas Inspired by Ella Fitzgerald</h1><span><br/></span>Celebrate the holidays with the timeless swing of Ella Fitzgerald, brought to life by vocalist and trombonist Casey Thomas‑Burns and her band in a joyful evening of festive jazz. In 1960, Ella Fitzgerald released the beloved holiday classic Ella Wishes You a Swinging Christmas, a joyful, swing‑filled album cherished by generations. This holiday season, Casey Thomas‑Burns brings the music of this iconic album to life. “Swinging, singing, and sparkling,” Casey is a rising star of the Canadian jazz scene, blending Golden Age elegance with joyful New Orleans spirit. Join Casey and her band for a festive celebration of sparkling arrangements and holiday cheer.
""";
  schema:startDate "2026-12-16T19:30:00"^^xsd:dateTime;
