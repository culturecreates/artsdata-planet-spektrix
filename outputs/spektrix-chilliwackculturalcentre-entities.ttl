<http://www.spektrix.com/chilliwackculturalcentre/event/180801ACNRNVTNLQTNBRHMMHMPGLDKJCB>
  a schema:Event;
  schema:name "Dr. Mark Evered";
  schema:description """
	<h1>Miracles in the Womb with Dr. Mark Evered</h1><span><br/></span>The sequence of events that builds our internal and external sex organs, guides the development of our gender identity and sexual orientation, and ensures that each of us is at least a little bit different from anyone else.
""";
  schema:startDate "2026-10-15T10:00:00"^^xsd:dateTime;
