<http://www.spektrix.com/chilliwackculturalcentre/event/142801ACCMGHVPCLJQCSQSPMHKNMMPRLJ>
  a schema:Event;
  schema:name "Quartetto Gelato";
  schema:description """
	<h1>Classical Music with Spark, Soul, and Swagger!</h1><span><br/></span>Virtuosic showpieces and romantic ballads, blazing gypsy tunes, and forgotten musical gems, brought vividly to life through dazzling multi‑instrumental mastery, define Quartetto Gelato, a popular and wonderfully unconventional classical quartet. With sold‑out performances in New York, Washington, L.A., London, Tokyo, Hong Kong, and beyond, this captivating ensemble has delighted audiences and critics worldwide with its irresistible blend of musical virtuosity, artistic passion, and wit. Spanning the globe in style and repertoire, their performances feature classical masterworks, engaging vocals, and the infectious rhythms of tango, gypsy, and klezmer music. Combined with their theatrical stage presence and relaxed humour, Quartetto Gelato creates an intimate, entertaining, and thoroughly unforgettable concert experience.
""";
  schema:startDate "2026-10-01T19:30:00"^^xsd:dateTime;
