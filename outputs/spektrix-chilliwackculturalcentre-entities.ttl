  a schema:Event;
  schema:name "Destination Broadway ";
  schema:description """
	<h1>Join CSOPA’s MainStage cast for their annual fundraising gala, Destination Broadway!</h1><span><br/></span>Come bid on an amazing collection of gift baskets and prizes and experience a joyful variety entertainment show while you’re there! The Chilliwack School Of Performing Arts is a non-profit youth theatre school in downtown Chilliwack. They rely on the generosity of the community to continue to offer theatre education and amazing programs. Destination Broadway is a student directed and performed fundraising variety show featuring numbers from musicals, dances, scenes, and more!
""";
