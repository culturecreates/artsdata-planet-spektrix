<http://www.spektrix.com/chilliwackculturalcentre/event/61401ATQDMVMSLPDTKCRQGQKNDHQSBBKR>
  a schema:Event;
  schema:name "Christmas with Ken Lavigne";
  schema:description """
	<h1>A joyful holiday celebration featuring beloved Canadian tenor Ken Lavigne.</h1><span><br/></span>Join the Chilliwack Symphony Orchestra, in collaboration with the Chilliwack Community Band, for A Chilliwack Family Christmas. Enjoy timeless seasonal favourites including Angels We Have Heard on High, In the Bleak Midwinter, Let It Snow, I’ll Be Home for Christmas, Santa Claus Is Coming to Town, and Hark! The Herald Angels Sing. This festive concert blends rich orchestral and band sounds with Ken Lavigne’s warm vocals to create a heartwarming experience for the whole family. Celebrate the magic of Christmas with music, community, and holiday cheer!
""";
  schema:startDate "2025-12-12T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/711b5bca-ff3f-49a5-acea-3008996b2ad8.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
