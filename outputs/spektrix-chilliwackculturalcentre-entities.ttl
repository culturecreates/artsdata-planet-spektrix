<http://www.spektrix.com/chilliwackculturalcentre/event/130001ASNPBJTQDQPGDNQTMRBPVHHPLCS>
  a schema:Event;
  schema:name "Larkk ";
  schema:description """
	<h1>Danielle McTaggart, best known as the powerhouse voice of JUNO-winning duo Dear Rouge, is stepping into a new creative chapter with her solo project, Larkk.</h1><span><br/></span>Trading indie‑rock intensity for a more intimate, atmospheric sound, she explores raw, poetic vulnerability through indie‑folk‑tinged songwriting. Her debut EP, Cinders, transforms personal poems into whispered, emotionally rich songs crafted with talented collaborators including producer Thomas D’Arcy (July Talk, Yukon Blonde, NOBRO, The Sheepdogs), and players Dani Nash (Andy Shauf, Field Guide), Drew Jurecka (Dua Lipa), and more. Larkk blends cinematic indie, alt‑pop, and ethereal electronic textures into a world that feels both expansive and deeply personal.
""";
  schema:startDate "2026-03-05T19:30:00"^^xsd:dateTime;
