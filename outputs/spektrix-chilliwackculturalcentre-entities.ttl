<http://www.spektrix.com/chilliwackculturalcentre/event/132201AGGDPHSTQDPGSCNHHHDSMSSCDCD>
  a schema:Event;
  schema:name "The Art of Banned Books";
  schema:description """
	<h1>Celebrate the freedom to read at The Art of Banned Books, a cozy gathering with snacks, coffee, and tea. </h1><span><br/></span>We’ll explore why banned and challenged books matter, discuss their impact in Canada, and reflect on the role readers play in protecting diverse voices and ideas.<span><br/></span><span><br/></span>Every participant will leave with a commonly challenged title in Canada to continue the conversation at home.<span><br/></span><span><br/></span>*Books will be secondhand
""";
