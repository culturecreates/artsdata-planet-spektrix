<http://www.spektrix.com/chilliwackculturalcentre/event/7001AGCLPBHTQLDRVGJQJGVCGDJKJPPNR>
  a schema:Event;
  schema:name "Chilliwack Beatlemania!";
  schema:description """
	Attention Beatles fans!<span><br/></span><span><br/></span>Join us Monday May 26 at 7:30pm at the Chilliwack Cultural Centre.<span><br/></span><span><br/></span>Travel through time - From early Ed Sullivan to Let it be, you’ll get all the hits. Experience this live Beatles show through all eras of their career, performed on stage by The Liverpool 4 with the same high energy, impeccable musicianship, showmanship, fun and humour.<span><br/></span><span><br/></span>The Liverpool 4, Canada’s Tribute to The Beatles have been delighting audiences for nearly two decades with their live high energy performance. They have performed thousands of shows across North America including appearances on Global TV's morning show, Maple Leaf Gardens, Universal Pictures, Massey Hall as well as countless theaters and festivals.<span><br/></span><span><br/></span>The show performance is 2 acts with a 20-minute intermission. It must be experienced to be believed. Come together and sing and dance along, clap your hands, stomp your feet, or just rattle your jewelry!
""";
  schema:startDate "2025-05-26T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/2d91fd2c-5833-46b7-a5ec-1002e0e5f2e6.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36867543;
  schema:keywords "Music";
  schema:duration "PT180M";
  schema:endDate "2025-05-26T22:30:00"^^xsd:dateTime .

_:1290a8eb9d794355b3e34223272b36867543 a schema:AggregateOffer;
  schema:lowPrice "60.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/chilliwackculturalcentre/event/100201AHNJCLCDDMMSQNCTBGTQMRSCKJN>
  a schema:Event;
  schema:name "Chilliwack Beatlemania!";
  schema:description """
	<h1>Travel Through Time with The Beatles!</h1><span><br/></span>From the electrifying Ed Sullivan debut to the soul-stirring Let It Be, The Liverpool 4 takes you on a magical journey through every iconic era of The Beatles’ legendary career. Experience the unforgettable hits live on stage — delivered with the same energy, impeccable musicianship, showmanship, fun, and cheeky humour that made the Fab Four a global sensation.<span><br/></span><span><br/></span>The Liverpool 4 — Canada’s Tribute to The Beatles — has been captivating audiences across North America for nearly 20 years. With thousands of shows under their belt, they've wowed crowds at venues like Maple Leaf Gardens, Massey Hall, Global TV’s Morning Show, and even Universal Pictures events — not to mention countless theatres and festivals coast to coast. This live concert features two sets with a 20-minute intermission. Whether you're singing along, dancing in the aisles, or just rattling your jewelry — you'll feel the magic of Beatlemania all over again.<span><br/></span>Come Together — and relive the greatest music ever made!<span><br/></span>
""";
  schema:startDate "2026-06-12T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/e391f443-4025-4c97-9a3f-1d6a046ca97d.jpg>;
  schema:location <https://spektrix.com/chilliwackculturalcentre/location/4201ASVGBHHRTVLQBSRVKDQCKNHHDCTSJ>;
  schema:offers _:1290a8eb9d794355b3e34223272b36867544;
  schema:keywords "Tribute Band";
  schema:duration "PT60M";
  schema:endDate "2026-06-12T20:30:00"^^xsd:dateTime .

