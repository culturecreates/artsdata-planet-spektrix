<http://www.spektrix.com/chilliwackculturalcentre/event/56001APNJBQMGSPLVLVDSPKGGCMCMVLTQ>
  a schema:Event;
  schema:name "The Four Seasons - Flamenco";
  schema:description """
	<h1>Vivaldi and Flamenco meld in this fiery performance by the Karen Flamenco Dance Company!</h1><span><br/></span>Passionate flamenco meets Vivaldi’s Four Seasons in this journey through the changing seasons. Experience the dawn of Spring and the bounty of Autumn with flawless footwork, pounding percussion, and rhythmic castanets. With live musical accompaniment on the flamenco guitar and cantaora, the impeccable dancers from Karen Flamenco Dance Company electrify the stage with sensual grace and powerful choreography. Uniquely diverse and evocative, The Four Seasons will lead audiences through the heat of summer to the sharp cold of winter.
""";
  schema:startDate "2026-02-14T19:30:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/chilliwackculturalcentre/files/876003fe-af83-4f29-99ec-fdc4b0c37cdb.jpg>;
