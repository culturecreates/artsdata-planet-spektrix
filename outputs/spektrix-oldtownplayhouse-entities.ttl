<http://www.spektrix.com/oldtownplayhouse/event/16801ANHJRBJLNRBNVQDKPGNSLJNKRTQV>
  a schema:Event;
  schema:name "OTP One Day University";
  schema:description """
	<h2>A Quarterly Educational Workshop Experience For Adults 18+</h2>This half-day Saturday morning workshop will feature a rotating variety of topics and hands-on experience for participants, allowing them to gain skills and pique interest in all parts of the theater. <span><br/></span><span><br/></span><span class=\"BoldText\">Topics for Saturday, May 3:</span><span><br/></span><span><br/></span><span class=\"BoldText\">Session One: \"The Dance Audition\" Masterclass</span><span><br/></span><span class=\"ItalicText\">Veronica Diebold Pointon, Facilitator</span><span><br/></span>Learn how to move your body to the best of your ability and gain confidence to be prepared for any dance audition!  Increase your knowledge around classic dance warmups that allow you to gather an understanding of what works best for your body type. Gain knowledge around proper body alignment and how to activate muscles correctly to aid with supporting your body and breathing for singing techniques. Participants will also learn a simple, fun dance combo as part of a \"mock audition\" in which the class participants will receive on-the-spot feedback, helping to gain confidence and HAVE FUN!<span><br/></span><span><br/></span><span class=\"BoldText\">Session Two: 65 Years of Old Town Playhouse</span><span><br/></span><span class=\"ItalicText\">Wes Curry, Facilitator </span><span><br/></span>Take a quick journey through the first 64 years of Old Town Playhouse history archives as we gear up to celebrate our 65th season!! <span><br/></span>
""";
  schema:startDate "2025-05-03T09:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/oldtownplayhouse/files/071997d1-a778-4d6a-a0be-e9bccbfdc37d.jpg>;
  schema:location <https://spektrix.com/oldtownplayhouse/location/407AGBMNMGJMSNPVKJMSNVLRPHJBTDPHT>;
  schema:offers _:4bdb307e74294ec49983d160f745219a6246;
  schema:duration "PT60M";
  schema:endDate "2025-05-03T10:00:00"^^xsd:dateTime .

_:4bdb307e74294ec49983d160f745219a6246 a schema:AggregateOffer;
  schema:lowPrice "0.0";
  schema:priceCurrency "CAD" .

<http://www.spektrix.com/oldtownplayhouse/event/22603APPRDVVLPQHSCHLMHKDQGKQKHTRV>
  a schema:Event;
  schema:name "Paint Night";
  schema:description """
	<span class=\"BoldText\">by Carey Crim</span><span><br/></span><span><br/></span>Six women gather for a much-needed girls' night out. The plan is to eat, drink and create works of art at a local paint and sip night while celebrating a bride to be. But as the alcohol flows, so do their thoughts on motherhood and womanhood, and their carefully curated lives get hilariously and heartbreakingly real.<span><br/></span><span><br/></span>You are the best judge of what is appropriate for those you bring to the theatre, but OTP recommends this show for Mature Audiences due to discussions of mental health/bi-polar disorder, sexual language and conversations throughout, and discussions of a child dealing with trans issues.<span><br/></span><span><br/></span><span class=\"BoldText\">Directed by: Stephanie Young</span><span><br/></span><span><br/></span>Tickets are $25, general admission. Please read our <a target=\"_top\" href=\"https://www.oldtownplayhouse.com/performances/plan/\">Plan Your Visit</a> page before purchasing tickets.<span><br/></span><span><br/></span>Please call the Box Office for discounted pricing: Groups of 8 or more, Two-on-the-Town card holders, Military or Students with ID, or if you wish to attend with a Service Dog.<span><br/></span><span><br/></span>If sold out, please contact the OTP Box Office to be added to the waiting list.<span><br/></span><span><br/></span>No refunds; exchanges often possible more than 24 hours before a performance.<span><br/></span><span><br/></span><span class=\"ItalicText\">Paint Night</span> is presented through special arrangement with <span class=\"ItalicText\">TRW PLAYS</span>, 1180 Avenue of the Americas, Suite 640, New York, NY 10036. www.trwplays.com<span><br/></span><span><br/></span>
""";
  schema:startDate "2026-03-13T19:30:00"^^xsd:dateTime;
