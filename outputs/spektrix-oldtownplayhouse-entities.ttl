<http://www.spektrix.com/oldtownplayhouse/event/56801AMQDSPDMMJNCTTQJGQMCTDBSSSGM>
  a schema:Event;
  schema:name "Teen Studio Factory - The Complete History of Theatre Abridged";
  schema:description """
	For ages 13 to 18 years. This 2-week camp brings students an chance to enhance their acting skills while working towards a performance. The campers will also get the opportunity to work with guest artists and help create the sets, props, and costumes for the performance. Camp meets Monday - Friday from 9:30am - 3:30pm, July 20 - July 31 with performances on July 31 & August 1, 2026.<span><br/></span>If Sold Out, please call the Education Office (231) 947-2210 x102 to be placed on our Waitlist.<span><br/></span><span class=\"BoldText\">If registering multiple students, please be sure to fill out name and emergency information for additional students in the box provided at checkout.</span>
""";
  schema:startDate "2026-07-20T09:30:00"^^xsd:dateTime;
