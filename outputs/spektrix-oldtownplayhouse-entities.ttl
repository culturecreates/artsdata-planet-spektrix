<http://www.spektrix.com/oldtownplayhouse/event/27801AGBRBTMKNGSLNDRVNGSHQJPSLPHH>
  a schema:Event;
  schema:name "The Rocky Horror Show";
  schema:description """
	<span class=\"BoldText\">Book, Music and Lyrics by Richard O'Brien</span><span><br/></span><span><br/></span>Celebrating the 50th anniversary! Two squeaky clean college kids - Brad and his fiancée Janet - are on their way to visit a former professor when their car breaks down outside an abandoned movie theatre. There, they meet the charismatic and cross-dressing mad scientist, Dr. Frank'n'Furter. A science-fiction and horror-themed production that is a satirical tribute to B-movies and an unforgettable adventure filled with fun, frolics, frocks and frivolity.<span><br/></span><span><br/></span>You are the best judge of what is appropriate for those you bring to the theatre, but OTP recommends this show for Mature Audiences due to language, sexual themes and discussions throughout, and violence.<span><br/></span><span><br/></span><span class=\"BoldText\">Directed by: Aria Davis</span><span><br/></span><span><br/></span>Tickets are $35 for Adults, $25 for Youth under 18. Please read our <a target=\"_top\" href=\"https://www.oldtownplayhouse.com/performances/plan-your-visit.html\">Plan Your Visit</a> page before purchasing tickets.<span><br/></span><span><br/></span>PROP BAGS WILL BE AVAILABLE FOR A SUGGESTED DONATION. PLEASE DO NOT BRING YOUR OWN.<span><br/></span><span><br/></span>Please call the Box Office for discounted pricing: Partial View seats, Groups of 8 or more, Two-on-the-Town card holders, Military or Students with ID, or if you wish to attend with a Service Dog.<span><br/></span><span><br/></span>If sold out, please contact the OTP Box Office to be added to the waiting list.<span><br/></span><span><br/></span>No refunds; exchanges often possible more than 24 hours before a performance.<span><br/></span><span><br/></span>THE ROCKY HORROR SHOW is presented by arrangement with Concord Theatricals. www.concordtheatricals.com<span><br/></span><span><br/></span>
""";
  schema:startDate "2025-10-24T19:30:00"^^xsd:dateTime;
