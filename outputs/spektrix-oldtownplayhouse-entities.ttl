pan><span class=\"BoldText\">No refunds;</span> exchanges are often possible. See our <a target=\"_top\" href=\" https://www.oldtownplayhouse.com/performances/plan/exchange-and-refund-policy.html\">Exchange and Refund Policy</a> for options if you cannot use your tickets.<span><br/></span><span><br/></span><span class=\"BoldText\">If sold out</span>, please contact the Box Office to be added to the waiting list.<span><br/></span><span><br/></span><span class=\"ItalicText\">PIPPIN</span> is presented through special arrangement with Music Theatre International (MTI). All authorized performance materials are also supplied by MTI.<span><br/></span>www.mtishows.com<span><br/></span>
""";
  schema:startDate "2027-04-17T14:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/oldtownplayhouse/files/fa9010cd-1af5-4885-bfa2-0158571c0e7a.jpg>;
  schema:location <https://spektrix.com/oldtownplayhouse/location/407AGBMNMGJMSNPVKJMSNVLRPHJBTDPHT>;
