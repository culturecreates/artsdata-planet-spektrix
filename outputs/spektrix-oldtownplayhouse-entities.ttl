<http://www.spektrix.com/oldtownplayhouse/event/69601ANKVPKVRSPMHRSMLLQSTRLSKPHPR>
  a schema:Event;
  schema:name "A Seussified Christmas Carol";
  schema:description """
	<h2>by Peter Bloedel</h2><span><br/></span>A whimsical reinvention of Dickens' most beloved Christmas story in wacky rhymed couplets. With zoot fruited juices and binka bird geese, from Bed-Headed Fred to Timmy Loo Hoo, this tale of glorious holiday cheer is similar to something Dr. Seuss might have come up with - if he ever had his way with the story...featuring our Young Company actors. <span><br/></span><span><br/></span><span class=\"BoldText\">About Tickets:</span> Tickets are $15. Please contact the Box Office if you wish to attend with a Service Dog.<span><br/></span><span><br/></span><span class=\"BoldText\">Attending a Performance:</span> We recommend that you review our <a target=\"_top\" href=\" https://www.oldtownplayhouse.com/performances/plan/\">Plan Your Visit</a> pages before purchasing tickets.<span><br/></span><span><br/></span><span class=\"BoldText\">No refunds;</span> exchanges are often possible. See our <a target=\"_top\" href=\" https://www.oldtownplayhouse.com/performances/plan/exchange-and-refund-policy.html\">Exchange and Refund Policy</a> for options if you cannot use your tickets.<span><br/></span><span><br/></span><span class=\"BoldText\">If sold out</span>, please contact the Box Office to be added to the waiting list.<span><br/></span><span><br/></span><span class=\"ItalicText\">A SEUSSIFIED CHRISTMAS CAROL</span> (FULL-LENGTH) is presented by arrangement with Concord Theatricals on behalf of<span><br/></span>Playscripts.<span><br/></span>www.concordtheatricals.com<span><br/></span><span><br/></span>
""";
  schema:startDate "2026-11-20T19:00:00"^^xsd:dateTime;
  schema:image <https://system.spektrix.com/oldtownplayhouse/files/deef6b84-80a8-4e7d-9168-5ed0468aa420.jpg>;
