<http://www.spektrix.com/oldtownplayhouse/event/70201ADHVPVLHCVCVCTRPRPPPJCCSKTGL>
  a schema:Event;
  schema:name "How to Train Your Dragon The Musical JR.";
  schema:description """
	<h2>Book & Lyrics by Kate Thomas</h2><h2>Original Music & Lyrics by Veronica Mansour</h2>Based on the DreamWorks Animation Motion Picture<span><br/></span>In association with the Universal Theatrical Group <span><br/></span><span><br/></span>A musical adaptation of the Dreamworks Animation hit movie: Hiccup is a misfit Viking boy who is teased for being different. Instead of joining the warrior tradition, he chooses to go exploring and encounters a ferocious dragon he names Toothless. Shocked to find the creature is not as dangerous as the village believes, Hiccup and Toothless face challenges that test their courage, loyalty, and belief in each other, discovering that the greatest strength comes from seeing the world differently. Experience fire-breathing action, epic adventure, and big laughs on our stage with Young Company actors!<span><br/></span><span><br/></span><span class=\"BoldText\">About Tickets:</span> Tickets are $15. Please contact the Box Office if you wish to attend with a Service Dog.<span><br/></span><span><br/></span><span class=\"BoldText\">Attending a Performance:</span> We recommend that you review our <a target=\"_top\" href=\" https://www.oldtownplayhouse.com/performances/plan/\">Plan Your Visit</a> pages before purchasing tickets.<span><br/></span><span><br/></span><span class=\"BoldText\">No refunds;</span> exchanges are often possible. See our <a target=\"_top\" href=\" https://www.oldtownplayhouse.com/performances/plan/exchange-and-refund-policy.html\">Exchange and Refund Policy</a> for options if you cannot use your tickets.<span><br/></span><span><br/></span><span class=\"BoldText\">If sold out</span>, please contact the Box Office to be added to the waiting list.<span><br/></span><span><br/></span><span class=\"ItalicText\">HOW TO TRAIN YOUR DRAGON THE MUSICAL JR.</span> is presented through special arrangement with Music Theatre International (MTI). All Authorized performance materials are supplied by MTI.<span><br/></span>www.MTIShows.com<span><br/></span>
""";
  schema:startDate "2027-02-19T19:00:00"^^xsd:dateTime;
